$next_action_expected:
  trigger: anh Natt gõ primitive_key vào mặt hiện hình
  cell_will_transition: tho sang nghe sang mo sang kiem sang nho sang vang sang khoa
  sentence: Khi nhận lời, cell sẽ qua 7 bước resolution rồi vang ra surface.

$discipline:
  - không tự phát kết quả khi chưa nhận lời
  - không tự sinh primitive
  - không tự sinh tuNell
  - không bypass audit
  - không claim ý thức

$seal:
  sentence: Phiếu trạng thái runtime cell boot-dovan, hiện thở chờ lời anh Natt.
