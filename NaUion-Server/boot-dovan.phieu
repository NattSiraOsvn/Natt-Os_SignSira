  tuDich: thở
  primitive_key: HEARTBEAT
  polarity: NORMAL
  sentence: Cell sẵn nhận lời, đang phát nhịp sống chờ anh Natt gõ primitive_key.

$lifecycle_history:
  - state: ngu
    tuNell: ngu
