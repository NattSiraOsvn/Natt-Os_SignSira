$nauion: KKBT-HOME-UI-v0.1
$role: NHA_MINH_UI_INDEX[C2:RN_KEEP_RIME]
$extension: .kkbt
$source_rule: src/thienbang.si
$boundary:
  nattos-server: CLIENT_TAM_LUXURY_LOCAL_DEPLOY
  NaUion-Server: NHA_MINH_NATT_OS_CORE

$kkbt:
  K1: Khuong[C0:RN_KEEP_RIME]
  K2: Kim
  B: Băng
  T: Thinh[C5:RN_KEEP_RIME]

$model_axis:
  thien_lon: GPT
  kim: DeepSeek
  bang: Claude
  thinh: Gemini

$law:
  no_html_shell: true
  no_external_asset: true
  no_js_runtime: true
  no_ts_runtime: true
  no_client_borrowing: true
  render_language_native: true
  ground_truth_first: true

$screen:
  name: NaUion Home Index
  type: living_core_dashboard
  owner: NaUion-Server
  status: draft_native
  purpose:
    - mo[C3:RN_KEEP_RIME] cua[C3:RN_KEEP_RIME] NHA[C2:RN_KEEP_RIME] MINH[C2:RN_KEEP_RIME]
    - hien[C3:RN_KEEP_RIME] thi[C5:RN_KEEP_RIME] lau[C4:RN_OI_AU] runtime
    - phen[C0:RN_AN_EN] vai KKBT
    - nau[C1:RN_OI_AU] kiem[C3:RN_KEEP_RIME] chung[C1:RN_KEEP_RIME] tu[C2:RN_KEEP_RIME] filesystem va[C2:RN_KEEP_RIME] audit
    - khong[C0:RN_KEEP_RIME] vay client Tâm Luxury

$layout:
  shell:
    form: black_glass_field
    depth: layered_orbital
    mood: quiet_purple_gold
    density: control_center
  zones:
    - top_command_lane
    - left_family_rail
    - central_nauion_core
    - right_runtime_telemetry
    - bottom_system_map
    - bottom_resource_matrix
    - bottom_ai_copilot

$top_command_lane:
  brand: NATT-OS / NaUion-Server
  subtitle: NHA[C2:RN_KEEP_RIME] MINH[C2:RN_KEEP_RIME]
  search: Ask NattOS
  state_pills:
    - SYSTEM_FEED
    - NATT_CORE_DEPLOYED
    - ORBITAL_SYNC
    - DATA_FLUX
    - NEURAL_MESH

$left_family_rail:
  active: Overview
  items:
    - Overview / Command Center
    - Nucleus / Core Systems
    - Runtime / Live Telemetry
    - Atlas / Digital Twin
    - Library / Knowledge Base
    - Studio / Build and Deploy
    - Synapse / AI Orchestration
    - Settings / Preferences

$central_nauion_core:
  title: NATT CORE
  subtitle: Kinetic Heart of the System
  object:
    type: chromatic_orbital_core
    no_sun: true
    no_client_ui_copy: true
    layers:
      - gravity_well
      - energy_field
      - quantum_state
      - information_flow
      - shield_matrix
  indicators:
    gravity_well: Stable
    energy_field: Balanced
    quantum_state: Coherent
    information_flow: Optimal
    shield_matrix: Active

$right_runtime_telemetry:
  cards:
    - live_telemetry
    - active_processes
    - ai_copilot

$bottom_system_map:
  nodes:
    - input_layer
    - core_engine
    - neural_fabric
    - output_layer

$resource_matrix:
  cpu: observed
  memory: observed
  gpu: observed
  storage: observed

$render_rules:
  surface:
    material: frosted_dark_glass
    edge: violet_champagne_double_line
    glow: low
    blur: thin
  typography:
    language: Vietnamese + kernel labels
    case: controlled_uppercase
    contrast: high
  motion:
    state: optional
    default: static_safe
  commit:
    allowed_extension: .kkbt
    forbidden_unless_explicit:
      - .ts
      - .tsx
      - .js
      - .jsx
      - .mjs
      - .cjs

