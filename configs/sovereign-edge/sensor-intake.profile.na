physical_intake:
init_profile: nattos.physical.intake.432hz
workstation_role: physical_intake_gateway
preprocess:
- raw_filter
- normalize
- quality_check
- temporary_cache
- pre_audit
input_channels:
- camera
- scale
- spectrum_meter
- furnace
- sensor
- IoT
- industrial_bus
