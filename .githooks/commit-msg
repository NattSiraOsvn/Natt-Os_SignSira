#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
msg="$(cat "$msg_file")"
subject="$(printf "%s" "$msg" | sed -n '1p')"

case "$subject" in
  Merge*|Revert*|fixup!*|squash!*) exit 0 ;;
esac

if ! printf "%s" "$subject" | grep -Eq '^(feat|fix|docs|chore|refactor|test|build|ci|perf|security|audit|review|ratify|spec|doctrine|strategy|memory|proposal)\([a-zA-Z0-9._/-]+\): .+'; then
  echo "SIRAWAT COMMIT GATE: invalid subject."
  echo "Required: type(scope): message"
  exit 1
fi

required=(
  "Sirawat-From:"
  "Sirawat-To:"
  "Scope:"
  "Ground-Truth:"
  "Decision:"
  "Boundary:"
  "Next-Signal:"
)

for key in "${required[@]}"; do
  if ! grep -q "^${key}" "$msg_file"; then
    echo "SIRAWAT COMMIT GATE: missing body field: ${key}"
    exit 1
  fi
done

exit 0
