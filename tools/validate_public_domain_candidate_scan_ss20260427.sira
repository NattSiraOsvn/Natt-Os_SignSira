#!/usr/bin/env node
const fs = require("fs");

const file = "docs/runtime/public_domain_candidate_scan_ss20260427.na";
const text = fs.readFileSync(file, "utf8");

const must = [
  "@scope public-domain dns mail web",
  "@private_namespace excluded",
  "Scan này chỉ liệt kê domain public thật đã xuất hiện trong repo.",
  "Không kết luận quyền sở hữu domain.",
  "Brand-related public domain candidates",
  "Recommendation rule",
  "Mail public cần tối thiểu:",
  "MX",
  "SPF",
  "DKIM",
  "DMARC"
];

const forbiddenUnsafe = [
  "`.sira` là domain public",
  "`.anc` là domain public",
  "đã xác nhận sở hữu",
  "production-ready"
];

let errors = [];

for (const s of must) {
  if (!text.includes(s)) errors.push("missing required fragment: " + s);
}

for (const s of forbiddenUnsafe) {
  if (text.includes(s)) errors.push("forbidden unsafe wording: " + s);
}

if (errors.length) {
  console.error("public domain candidate scan validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("public domain candidate scan validation: pass");
console.log("file=" + file);
