#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "nattos_platform_independence_evidence_ss20260427.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing nattos platform independence evidence");
} else {
  const c = fs.readFileSync(file, "utf8");

  [
    "nattos platform independence evidence ss20260427",
    "evidence type HAL",
    "evidence type ISA",
    "evidence type QoS",
    "evidence type API",
    "open flag",
    "claim_level: observed"
  ].forEach(clause => must(c.includes(clause), "missing evidence clause: " + clause));

  [
    "production-ready",
    "guaranteed",
    "complete coverage",
    "fully audited"
  ].forEach(mark => must(!c.toLowerCase().includes(mark), "forbidden evidence wording: " + mark));
}

if (errors.length) {
  console.error("nattos platform independence evidence validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("nattos platform independence evidence validation: pass");
console.log("file=docs/runtime/nattos_platform_independence_evidence_ss20260427.na");
