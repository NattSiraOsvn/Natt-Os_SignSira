#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const ROOT = process.cwd();
const evidence = path.join(ROOT, "docs", "runtime", "TS_CLEANUP_BATCH2B_PROMOTE_TO_Sira_20260424.na");

if (!fs.existsSync(evidence)) {
  console.error("Missing evidence:", evidence);
  process.exit(1);
}

const content = fs.readFileSync(evidence, "utf8");

const required = [
  "PROMOTE_TO_Sira_CANDIDATE",
  "Batch này chỉ xử lý nhóm candidate",
  "renamed",
  "skipped"
];

const missing = required.filter(x => !content.includes(x));

if (missing.length) {
  console.error("TS CLEANUP BATCH2B validation: fail");
  for (const x of missing) console.error(" - missing " + x);
  process.exit(1);
}

console.log("TS CLEANUP BATCH2B validation: pass");
console.log("scope=PROMOTE_TO_Sira_CANDIDATE only");
console.log("mode=rename JS-compatible candidates to .sira");
