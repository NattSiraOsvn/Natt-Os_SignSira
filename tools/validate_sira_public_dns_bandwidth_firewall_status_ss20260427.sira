#!/usr/bin/env node
const fs = require("fs");

const file = "docs/runtime/sira_public_dns_bandwidth_firewall_status_ss20260427.na";
const text = fs.readFileSync(file, "utf8");

const must = [
  "@scope public dns bandwidth firewall policy evidence",
  "@runtime_scope excluded",
  "Không tạo gate mới.",
  "Phần runtime thuộc lane Anh + Bối.",
  "docs/runtime/sira_mail_ip_bandwidth_readiness_latest.na",
  "docs/runtime/sira_dns_infrastructure_bandwidth_baseline_20260426.na",
  "docs/runtime/sira_wired_edge_firewall_audit_evidence_20260426.na",
  "claim_ip_internal: PASS",
  "claim_mail_provider_mode: PENDING",
  "claim_self_host_mail: BLOCKED",
  "Mail Internet cần domain public thật.",
  "Self-host mail luôn BLOCKED nếu chưa có MTA local listening."
];

const forbidden = [
  "production-ready",
  "self-host mail production đã sẵn sàng",
  "mail provider mode production đã sẵn sàng",
  "runtime production public exposure đã sẵn sàng",
];

let errors = [];

for (const s of must) {
  if (!text.includes(s)) errors.push("missing required fragment: " + s);
}

for (const s of forbidden) {
  if (text.includes(s)) errors.push("forbidden wording: " + s);
}

if (errors.length) {
  console.error("sira public dns bandwidth firewall status validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira public dns bandwidth firewall status validation: pass");
console.log("file=" + file);
