#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const root = process.cwd();
const runner = path.join(root, "tools", "run_sira_dns_smoke_matrix.sira");
const evidence = path.join(root, "docs", "runtime", "sira_dns_smoke_runner_evidence_20260425.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(runner)) {
  errors.push("missing smoke runner");
} else {
  const r = fs.readFileSync(runner, "utf8");
  [
    "natt_domain_gateway.sira",
    "Host: host",
    "routeGateDeny",
    "not_denied_by_route_gate",
    "localhost is transport target"
  ].forEach(clause => must(r.includes(clause), "runner missing clause: " + clause));
}

if (!fs.existsSync(evidence)) {
  errors.push("missing smoke runner evidence");
} else {
  const c = fs.readFileSync(evidence, "utf8");
  [
    "sira dns smoke runner evidence",
    "status: pass",
    "runner này khởi động gateway tạm thời",
    "unknown.sira",
    "mail.sira",
    "127.0.0.1",
    "not_denied_by_route_gate"
  ].forEach(clause => must(c.includes(clause), "evidence missing clause: " + clause));

  must(!c.includes("| mismatch |"), "evidence has mismatch");
  must(!c.includes("transport_error"), "evidence has transport_error");
}

if (errors.length) {
  console.error("sira dns smoke runner validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira dns smoke runner validation: pass");
console.log("file=docs/runtime/sira_dns_smoke_runner_evidence_20260425.na");
