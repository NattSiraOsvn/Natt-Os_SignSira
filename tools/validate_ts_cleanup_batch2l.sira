#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const ROOT = process.cwd();
const evidence = path.join(ROOT, "docs", "runtime", "TS_CLEANUP_BATCH2L_DEEP_LIGHT_TO_Sira_20260424.na");

if (!fs.existsSync(evidence)) {
  console.error("Missing evidence:", evidence);
  process.exit(1);
}

const content = fs.readFileSync(evidence, "utf8");

const required = [
  "POSSIBLE_MANUAL_LIGHT_TRANSLATION",
  "Deep Light Translation",
  "Renamed",
  "Skipped"
];

const missing = required.filter(x => !content.includes(x));

if (missing.length) {
  console.error("TS CLEANUP BATCH2L validation: fail");
  for (const x of missing) console.error(" - missing " + x);
  process.exit(1);
}

console.log("TS CLEANUP BATCH2L validation: pass");
console.log("scope=POSSIBLE_MANUAL_LIGHT_TRANSLATION only");
console.log("mode=light translation if safe, otherwise skip");
