#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sira_dns_strict_allowlist_rebind_evidence_20260426.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

function host(name) {
  return name + "." + "sira";
}

function wifiIp() {
  return "192.168.1.238";
}

function record(name) {
  return wifiIp() + " " + host(name);
}

if (!fs.existsSync(file)) {
  errors.push("missing strict allowlist rebind evidence");
} else {
  const c = fs.readFileSync(file, "utf8");
  const lower = c.toLowerCase();

  [
    "sira dns strict allowlist rebind evidence",
    "status: strict-allowlist-rebound",
    "active coredns daemon reads /usr/local/etc/coredns/Corefile",
    "strict allow-list includes anc identity host required by runtime gate",
    "khai ip remains dns-only",
    "deny check uses short dns answer only",
    record("anc"),
    record("apps"),
    record("mach"),
    record("core"),
    record("audit"),
    record("render"),
    record("tam"),
    "@127.0.0.1 " + host("anc") + ": allow",
    "@192.168.1.238 " + host("anc") + ": allow",
    "@127.0.0.1 " + host("apps") + ": allow",
    "@192.168.1.238 " + host("apps") + ": allow",
    "@127.0.0.1 " + host("unknown") + ": deny",
    "@192.168.1.238 " + host("unknown") + ": deny",
    "do not return live ip"
  ].forEach(clause => must(c.includes(clause), "missing strict allowlist clause: " + clause));

  [
    "curl",
    "safari",
    "browser adapter",
    "transport smoke",
    "runtime smoke",
    "wildcard -> allow",
    "allow wildcard",
    "production-ready",
  ].forEach(mark => must(!lower.includes(mark), "forbidden strict allowlist wording: " + mark));
}

if (errors.length) {
  console.error("sira dns strict allowlist rebind validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira dns strict allowlist rebind validation: pass");
console.log("file=docs/runtime/sira_dns_strict_allowlist_rebind_evidence_20260426.na");
