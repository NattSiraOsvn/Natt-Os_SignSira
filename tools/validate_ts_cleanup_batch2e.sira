#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const ROOT = process.cwd();
const evidence = path.join(ROOT, "docs", "runtime", "TS_CLEANUP_BATCH2E_MEDIUM_TO_SIRA_20260424.na");

if (!fs.existsSync(evidence)) {
  console.error("Missing evidence:", evidence);
  process.exit(1);
}

const content = fs.readFileSync(evidence, "utf8");

const required = [
  "MEDIUM_LIGHT_TRANSLATION_TO_SIRA",
  "renamed",
  "skipped",
  "translation"
];

const missing = required.filter(x => !content.includes(x));

if (missing.length) {
  console.error("TS CLEANUP BATCH2E VALIDATION: FAIL");
  for (const x of missing) console.error(" - missing " + x);
  process.exit(1);
}

console.log("TS CLEANUP BATCH2E VALIDATION: PASS");
console.log("scope=MEDIUM_LIGHT_TRANSLATION_TO_SIRA only");
console.log("mode=light TS syntax translation then .sira");
