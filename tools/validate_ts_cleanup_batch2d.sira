#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const ROOT = process.cwd();
const evidence = path.join(ROOT, "docs", "runtime", "TS_CLEANUP_BATCH2D_EASY_TO_Sira_20260424.na");

if (!fs.existsSync(evidence)) {
  console.error("Missing evidence:", evidence);
  process.exit(1);
}

const content = fs.readFileSync(evidence, "utf8");

const required = [
  "EASY_JS_COMPATIBLE_TO_Sira",
  "renamed",
  "skipped",
  "patched_refs"
];

const missing = required.filter(x => !content.includes(x));

if (missing.length) {
  console.error("TS CLEANUP BATCH2D validation: fail");
  for (const x of missing) console.error(" - missing " + x);
  process.exit(1);
}

console.log("TS CLEANUP BATCH2D validation: pass");
console.log("scope=EASY_JS_COMPATIBLE_TO_Sira only");
console.log("mode=rename easy JS-compatible runtime files to .sira");
