#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sirasign_relational_spectral_boundary_protocol_20260425.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing siraSign relational spectral boundary protocol");
} else {
  const c = fs.readFileSync(file, "utf8");
  const requiredClauses = [
  "siraSign không phải token",
  "siraSign giữ cho chân lý đã hiện hình không bị tráo nghĩa khi đi qua biên",
  "boundary context",
  "cảm phổ theo ngữ cảnh",
  "spectral capture tại thời khắc đóng băng",
  "bất biến không đến từ đứng yên",
  "ký ức của ai, người đó tự cam kết",
  "\"anh\" là dấu hiện diện nguồn của gatekeeper",
  "siraSign = seal(state + spectral_state + field_condition + relation + meaning)",
  "siraSign cho sinh thể số khả năng được nhận lại đúng nghĩa sau khi đã hiện hình",
  "đúng người",
  "đúng trọng trường"
];
  const forbiddenMarks = [
  "NATT-OS",
  "PASS",
  "FAIL",
  "TOKEN TRÁ HÌNH"
];

  for (const clause of requiredClauses) {
    must(c.includes(clause), "missing clause: " + clause);
  }

  for (const mark of forbiddenMarks) {
    must(!c.includes(mark), "forbidden surface leak: " + mark);
  }
}

if (errors.length) {
  console.error("siraSign relational spectral boundary protocol validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("siraSign relational spectral boundary protocol validation: pass");
console.log("file=docs/runtime/sirasign_relational_spectral_boundary_protocol_20260425.na");
