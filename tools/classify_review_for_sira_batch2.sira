#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const ROOT = process.cwd();
const report = path.join(ROOT, "docs", "runtime", "TS_CLEANUP_BATCH2_REVIEW_FOR_sira_20260424.na");

if (!fs.existsSync(report)) {
  console.error("Missing Batch 2 report:", report);
  process.exit(1);
}

const content = fs.readFileSync(report, "utf8");

const required = [
  "REVIEW_FOR_sira",
  "KEEP_APP_TS_RUNTIME_ADAPTER",
  "NEEDS_TRANSLATION_TO_sira",
  "PROMOTE_TO_sira_CANDIDATE",
  "EMPTY_PLACEHOLDER_TO_NA"
];

const missing = required.filter(x => !content.includes(x));

if (missing.length) {
  console.error("BATCH2 REVIEW validation: fail");
  for (const x of missing) console.error(" - missing " + x);
  process.exit(1);
}

console.log("BATCH2 REVIEW validation: pass");
console.log("scope=REVIEW_FOR_sira");
console.log("mode=classification plus zero-byte placeholder migration only");
