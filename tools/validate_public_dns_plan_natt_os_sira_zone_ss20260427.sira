#!/usr/bin/env node
const fs = require("fs");

const file = "docs/runtime/public_dns_plan_natt_os_sira_zone_ss20260427.na";
const text = fs.readFileSync(file, "utf8");

const must = [
  "@scope public-domain dns mail web edge",
  "@runtime_scope excluded",
  "Không đụng file `src/contracts/event-bus-test.sira`.",
  "`natt-os.com`",
  "`sira.zone`",
  "MX",
  "SPF",
  "DKIM",
  "DMARC",
  "PTR",
  "Chưa được claim:",
  "domain ownership confirmed",
  "public runtime exposure"
];

const forbidden = [
  "production-ready",
  "đã xác nhận sở hữu",
  "mail provider production đã sẵn sàng",
  "self-host mail production đã sẵn sàng"
];

let errors = [];

for (const s of must) {
  if (!text.includes(s)) errors.push("missing required fragment: " + s);
}

for (const s of forbidden) {
  if (text.includes(s)) errors.push("forbidden unsafe wording: " + s);
}

if (errors.length) {
  console.error("public dns plan validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("public dns plan validation: pass");
console.log("file=" + file);
