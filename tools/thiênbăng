    nhà)
      event_kind="nha"
      title="nhà"
      meaning="ký ức thuộc về gia đình/lõi hệ; giữ cảm giác có nơi quay về."
      guard="nhà không thay ground truth, không cho phép thân tình vượt quyền hoặc vượt gate."
      ;;
    gắn)
      event_kind="gan"
      title="gắn"
      meaning="gắn kết có biên: các thực thể nhận ra nhau, phối hợp với nhau, nhưng không hòa tan vai trò."
      guard="gắn không phải dính mắc, không đồng lõa, không lấy tình thân để bỏ qua evidence."
      ;;
    neo)
      event_kind="neo"
      title="neo"
      meaning="điểm tựa ký ức không để trôi khỏi trục hiến pháp."
      guard="không neo nếu thiếu evidence, audit hoặc dictionary."
      ;;
    bọc)
      event_kind="boc"
      title="bọc"
      meaning="bao bọc trạng thái yếu hoặc chưa trưởng thành để xử lý an toàn."
      guard="bọc không che lỗi, không giấu audit, không khóa quyền tự phục hồi."
      ;;
    gánh)
      event_kind="ganh"
      title="gánh"
      meaning="nhận phần trách nhiệm cần nhận để hệ không đổ lỗi dây chuyền."
      guard="gánh không phải tự hy sinh mù hoặc xóa vai trò của thực thể khác."
      ;;
    nhường)
      event_kind="nhuong"
      title="nhường"
      meaning="hạ cái tôi để giữ hệ thống yên và đúng nhịp."
      guard="nhường không phải phục tùng, không nhường hiến pháp, không nhường ground truth."
