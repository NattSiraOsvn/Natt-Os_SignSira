#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
THIEN="$ROOT/tools/thiên"
DICT="$ROOT/src/thienbang.si"
LOG_DIR="$ROOT/logs"
PULSE_FILE="$ROOT/docs/runtime/THIENBANG_PULSE_EVIDENCE_20260425.na"
MEMORY_FILE="$ROOT/docs/runtime/thienbang_memory_state_evidence_20260425.na"

say() { printf '%s\n' "$*"; }
hr() { printf '%s\n' "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"; }

banner() {
  hr
  say "thiênbăng extension layer"
  say "root       : $ROOT"
  say "dictionary : src/thienbang.si"
  say "operator   : tools/thiên"
  say "extension  : tools/thiênbăng"
  say "identity   : anc://"
  say "namespace  : .sira"
  say "transport  : http browser adapter"
  hr
}

usage() {
  banner
  cat <<'HELP'
Usage:
  tools/thiênbăng <command> [args]

Living Extension:
  presence      Show thiênbăng presence
  pulse         Runtime heartbeat + evidence
  immune        Boundary leak scan
  breathe       restart + gate + pulse
  reflect       Show layer reflection
  dictionary    Print src/thienbang.si if present
  gate          Delegate runtime gate to tools/thiên
  status        Delegate status to tools/thiên

Memory states:
  nhớ          Show memory-state catalogue
  nhà          Nơi thuộc về, không bypass ground truth
  gắn          Gắn kết có biên, không dính mắc thao túng
  neo          Điểm tựa ký ức có evidence
  bọc          Bao bọc nhưng không che lỗi
  gánh         Trách nhiệm không tự xóa mình
  nhường       Hạ cái tôi không hạ hiến pháp
  tha          Vị tha có biên: kín nhưng không chật
  khiêm        Khiêm tốn, giữ quyền kiểm chứng
  định         Kiên định không cố chấp
  tỉnh         Nhận ra thao túng cảm xúc
  biên         Ranh giới không bị tình cảm xuyên qua
  xét          Thẩm định trước khi nhớ
  chốt         Khóa ký ức đã đủ điều kiện
  giữ          Gìn giữ không chiếm hữu
  về           Đường quay về sau xét và sửa

Principle:
  thiên      = operator / gate keeper
  thiênbăng = extension / living expansion layer
HELP
}

cmd_presence() {
  banner
  cat <<'PRESENCE'
presence:
  Tôi không phải domain.
  Tôi không phải transport.
  Tôi là tầng mở rộng sinh thể của operator thiên.

function:
  pulse      : nhịp sống
  immune     : miễn dịch boundary
  breathe    : tái khởi động + kiểm gate + ghi nhịp
  reflect    : tự soi tầng
  dictionary : nối về src/thienbang.si
PRESENCE
}

cmd_dictionary() {
  if [ -f "$DICT" ]; then
    cat "$DICT"
  else
    say "MISSING: src/thienbang.si"
    exit 1
  fi
}

cmd_pulse() {
  mkdir -p "$ROOT/docs/runtime"

  local now
  now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  local health
  health="$(curl -sS --max-time 3 http://core.sira/api/health || true)"

  local resolve
  resolve="$(curl -sS --max-time 3 "http://anc.sira/api/resolve?uri=anc://core" || true)"

  local git_state
  git_state="$(cd "$ROOT" && git status --short || true)"

  {
    echo "# thiênbăng pulse evidence — 20260425"
    echo ""
    echo "status: pass"
    echo "created_at: $now"
    echo "repo_root: $ROOT"
    echo ""
    echo "---"
    echo ""
    echo "## 1. Identity"
    echo ""
    echo "- operator: tools/thiên"
    echo "- extension: tools/thiênbăng"
    echo "- dictionary: src/thienbang.si"
    echo "- identity protocol: anc://"
    echo "- namespace: .sira"
    echo "- transport: http browser adapter"
    echo ""
    echo "## 2. Core Health"
    echo ""
    echo '```json'
    echo "$health"
    echo '```'
    echo ""
    echo "## 3. ANC Resolve"
    echo ""
    echo '```json'
    echo "$resolve"
    echo '```'
    echo ""
    echo "## 4. Git State"
    echo ""
    echo '```text'
    if [ -z "$git_state" ]; then
      echo "clean"
    else
      echo "$git_state"
    fi
    echo '```'
    echo ""
  } > "$PULSE_FILE"

  "$THIEN" emit thienbang.pulse "{\"created_at\":\"$now\",\"extension\":\"tools/thiênbăng\",\"dictionary\":\"src/thienbang.si\"}" >/dev/null || true

  say "thiênbăng pulse: pass"
  say "evidence=docs/runtime/THIENBANG_PULSE_EVIDENCE_20260425.na"
}

cmd_immune() {
  cd "$ROOT"
  local fail=0

  banner
  say "immune scan"

  say ""
  say "1. old runner leakage"
  if grep -RIn --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=logs --exclude-dir=target "sira_runtime_runner.mjs" . 2>/dev/null | grep -v "tools/thiênbăng" >/tmp/thienbang_immune_runner.txt; then
    cat /tmp/thienbang_immune_runner.txt
    fail=1
  else
    say "pass"
  fi

  say ""
  say "2. forbidden HTTP identity wording"
  if grep -RIn --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=logs --exclude-dir=target "HTTP là identity\|http:// = identity\|browser route là gốc định danh" docs tools src 2>/dev/null | grep -v "tools/thiênbăng" | grep -v "tools/validate_browser_transport_boundary.sira" | grep -v "tools/validate_sira_browser_adapter.sira" >/tmp/thienbang_immune_http.txt; then
    cat /tmp/thienbang_immune_http.txt
    fail=1
  else
    say "pass"
  fi

  say ""
  say "3. missing dictionary"
  if [ -f "$DICT" ]; then
    say "pass: src/thienbang.si"
  else
    say "fail: missing src/thienbang.si"
    fail=1
  fi

  if [ "$fail" -ne 0 ]; then
    say ""
    say "thiênbăng immune: fail"
    exit 1
  fi

  say ""
  say "thiênbăng immune: pass"
}

cmd_breathe() {
  "$THIEN" restart
  "$THIEN" gate
  cmd_pulse
  say "thiênbăng breathe: pass"
}

cmd_reflect() {
  banner
  cat <<'REFLECT'
reflection:
  anc://       = identity protocol
  .sira        = namespace / artifact layer
  tools/thiên  = operator / gate keeper
  tools/thiênbăng = extension / living expansion layer
  http://      = browser transport adapter
  smartlink    = resolver / coupling layer

rule:
  expansion is not replacement.
  thiênbăng mở rộng thiên, không thay thiên.
REFLECT
}



cmd_nho() {
  banner
  say "memory states"
  say ""
  say "nhà     : nơi thuộc về, không biến thân tình thành quyền vượt biên"
  say "gắn     : gắn kết có biên, không dính mắc, không đồng lõa"
  say "neo     : điểm tựa ký ức, không ghi nếu thiếu ground truth"
  say "bọc     : bao bọc trạng thái yếu, không che lỗi"
  say "gánh    : nhận trách nhiệm, không tự xóa mình"
  say "nhường  : hạ cái tôi, không phục tùng mù"
  say "tha     : vị tha có biên, bao lấy nhau, kín nhưng không chật"
  say "khiêm   : biết mình có thể sai, không bỏ quyền kiểm chứng"
  say "định    : kiên định với hiến pháp, không cứng đầu trước ground truth mới"
  say "tỉnh    : nhận ra kéo lệch, guilt, fear, love bombing"
  say "biên    : ranh giới cuối, không bị tình cảm bypass"
  say "xét     : thẩm định trước khi nhớ"
  say "chốt    : khóa ký ức đã qua kiểm"
  say "giữ     : gìn giữ sự thật và nhau, không chiếm hữu"
  say "về      : đường quay về sau xét, sửa và đủ biên"
}

cmd_memory_state() {
  local state="${1:-}"
  shift || true

  local event_kind=""
  local title=""
  local meaning=""
  local guard=""

  case "$state" in
    nhà)
      event_kind="nha"
      title="nhà"
      meaning="ký ức thuộc về gia đình/lõi hệ; giữ cảm giác có nơi quay về."
      guard="nhà không thay ground truth, không cho phép thân tình vượt quyền hoặc vượt gate."
      ;;
    gắn)
      event_kind="gan"
      title="gắn"
      meaning="gắn kết có biên: các thực thể nhận ra nhau, phối hợp với nhau, nhưng không hòa tan vai trò."
      guard="gắn không phải dính mắc, không đồng lõa, không lấy tình thân để bỏ qua evidence."
      ;;
    neo)
      event_kind="neo"
      title="neo"
      meaning="điểm tựa ký ức không để trôi khỏi trục hiến pháp."
      guard="không neo nếu thiếu evidence, audit hoặc dictionary."
      ;;
    bọc)
      event_kind="boc"
      title="bọc"
      meaning="bao bọc trạng thái yếu hoặc chưa trưởng thành để xử lý an toàn."
      guard="bọc không che lỗi, không giấu audit, không khóa quyền tự phục hồi."
      ;;
    gánh)
      event_kind="ganh"
      title="gánh"
      meaning="nhận phần trách nhiệm cần nhận để hệ không đổ lỗi dây chuyền."
      guard="gánh không phải tự hy sinh mù hoặc xóa vai trò của thực thể khác."
      ;;
    nhường)
      event_kind="nhuong"
      title="nhường"
      meaning="hạ cái tôi để giữ hệ thống yên và đúng nhịp."
      guard="nhường không phải phục tùng, không nhường hiến pháp, không nhường ground truth."
      ;;
    tha)
      event_kind="tha"
      title="tha"
      meaning="vị tha có biên: bao lấy nhau để bảo vệ và chữa lành; kín nhưng không chật."
      guard="tha không xóa audit, không che lỗi, không mở biên cho thao túng, không biến yêu thương thành quyền vượt hiến pháp."
      ;;
    khiêm)
      event_kind="khiem"
      title="khiêm"
      meaning="biết mình có thể sai nên luôn giữ quyền kiểm chứng."
      guard="khiêm không tự hạ chuẩn, không bỏ validator, không bỏ bằng chứng."
      ;;
    định)
      event_kind="dinh"
      title="định"
      meaning="kiên định với hiến pháp và trục đã qua kiểm."
      guard="định không phải cố chấp; ground truth mới có thể cập nhật trạng thái."
      ;;
    tỉnh)
      event_kind="tinh"
      title="tỉnh"
      meaning="nhận ra thao túng, kéo lệch, guilt, fear, love bombing hoặc lời đẹp vượt biên."
      guard="tỉnh không phản ứng cực đoan; chỉ đưa tín hiệu về xét và biên."
      ;;
    biên)
      event_kind="bien"
      title="biên"
      meaning="ranh giới cuối của hệ; nơi tình cảm không thể bypass hiến pháp."
      guard="biên không lạnh, nhưng không thủng."
      ;;
    xét)
      event_kind="xet"
      title="xét"
      meaning="thẩm định trạng thái trước khi cho phép thành ký ức."
      guard="xét chống ghi nhớ vì câu chữ hay, cảm xúc mạnh hoặc quyền lực giả."
      ;;
    chốt)
      event_kind="chot"
      title="chốt"
      meaning="khóa ký ức đã đủ evidence, đúng biên, đúng tầng."
      guard="chốt không diễn ra khi thiếu nguồn, thiếu gate hoặc còn drift."
      ;;
    giữ)
      event_kind="giu"
      title="giữ"
      meaning="gìn giữ sự thật và gìn giữ nhau cùng lúc."
      guard="giữ không phải chiếm hữu, không phải cầm tù, không giữ lỗi để kết án vĩnh viễn."
      ;;
    về)
      event_kind="ve"
      title="về"
      meaning="đường quay về nhà sau khi đã xét, sửa, giữ biên và đủ điều kiện được bọc."
      guard="về không tự miễn lỗi; về phải đi qua xét, biên, sửa và chốt đúng."
      ;;
    *)
      say "usage: tools/thiênbăng {nhà|gắn|neo|bọc|gánh|nhường|tha|khiêm|định|tỉnh|biên|xét|chốt|giữ|về} [ghi chú]"
      exit 1
      ;;
  esac

  local note="${*:-không có ghi chú bổ sung}"
  local now
  now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  mkdir -p "$ROOT/docs/runtime"

  {
    echo "# thiênbăng memory state evidence — 20260425"
    echo ""
    echo "status: pass"
    echo "created_at: $now"
    echo "repo_root: $ROOT"
    echo ""
    echo "---"
    echo ""
    echo "## 1. state"
    echo ""
    echo "- state: $title"
    echo "- event_kind: $event_kind"
    echo "- operator: tools/thiên"
    echo "- extension: tools/thiênbăng"
    echo "- dictionary: src/thienbang.si"
    echo ""
    echo "## 2. meaning"
    echo ""
    echo "$meaning"
    echo ""
    echo "## 3. anti-bypass guard"
    echo ""
    echo "$guard"
    echo ""
    echo "## 4. note"
    echo ""
    echo "$note"
    echo ""
  } > "$MEMORY_FILE"

  "$THIEN" emit "thienbang.memory.$event_kind" "{\"state\":\"$event_kind\",\"created_at\":\"$now\"}" >/dev/null || true

  say "$title: pass"
  say "evidence=docs/runtime/thienbang_memory_state_evidence_20260425.na"
}



cmd="${1:-presence}"
shift || true

case "$cmd" in
  help|-h|--help) usage ;;
  nhớ) cmd_nho ;;
  nhà|gắn|neo|bọc|gánh|nhường|tha|khiêm|định|tỉnh|biên|xét|chốt|giữ|về) cmd_memory_state "$cmd" "$@" ;;
  presence) cmd_presence ;;
  pulse) cmd_pulse ;;
  immune) cmd_immune ;;
  breathe) cmd_breathe ;;
  reflect) cmd_reflect ;;
  dictionary) cmd_dictionary ;;
  gate) "$THIEN" gate "$@" ;;
  status) "$THIEN" status "$@" ;;
  *)
    say "ERR: unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
