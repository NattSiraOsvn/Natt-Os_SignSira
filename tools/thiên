#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOG_DIR="$ROOT/logs"
PID_FILE="$LOG_DIR/natt_domain_gateway_80.pid"
LOG_FILE="$LOG_DIR/natt_domain_gateway_80.log"
PORT="${NATT_PORT:-80}"

say() { printf '%s\n' "$*"; }
hr() { printf '%s\n' "────────────────────────────────────────────────────────────"; }

banner() {
  hr
  say "THIÊN OPERATOR CONSOLE"
  say "root      : $ROOT"
  say "identity  : anc://"
  say "namespace : .sira"
  say "operator  : tools/thiên"
  say "transport : http browser adapter"
  say "port      : $PORT"
  hr
}

usage() {
  banner
  cat <<'HELP'
Usage:
  tools/thiên <command> [args]

Identity:
  whoami                       Show Thiên operator identity
  identity                     Show identity manifest
  oath                         Show operating oath
  self                         Show identity + runtime status

Core:
  help                         Show this help
  routes                       Show canonical runtime routes
  gate                         Run single SIRA runtime gate and write evidence
  doctor                       gate + status + git status

Runtime:
  status                       Show process, PID, health
  health                       Query core.sira health
  restart                      Restart SIRA browser adapter on port 80
  stop                         Stop SIRA browser adapter
  log                          Tail gateway log
  open [apps|audit|tam|nauion|screens|core]  Open browser route

Validators:
  namespace                    Validate .sira namespace
  browser                      Validate SIRA browser adapter
  transport                    Validate browser transport boundary
  ts-adapter                   Validate SIRA TS translation adapter
  ts-plan                      Print TS translation plan

Resolver / Event:
  resolve <name>               Resolve anc://<name>
  emit <type> [json_payload]   Emit runtime event to core.sira

Artifact:
  run <file.sira> [...args]    Run a .sira artifact
  <file.sira> [...args]        Shortcut for run

Examples:
  tools/thiên gate
  tools/thiên restart
  tools/thiên resolve core
  tools/thiên emit runtime.manual_ping '{"from":"thien"}'
  tools/thiên run tools/sira_ts_translation_adapter.sira plan
HELP
}

run_sira() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    say "ERR: missing .sira target" >&2
    exit 1
  fi
  shift || true

  cd "$ROOT"
  export THIEN_TARGET="$target"

  exec node - "$@" <<'NODE_THIEN'
const fs = require("fs");
const path = require("path");
const Module = require("module");

const target = process.env.THIEN_TARGET;

if (!target) {
  console.error("Missing THIEN_TARGET");
  process.exit(1);
}

const targetPath = path.resolve(process.cwd(), target);

if (!fs.existsSync(targetPath)) {
  console.error("Thiên runtime file not found:", targetPath);
  process.exit(1);
}

if (!targetPath.endsWith(".sira")) {
  console.error("Thiên launcher only accepts .sira files:", targetPath);
  process.exit(1);
}

const code = fs.readFileSync(targetPath, "utf8");

process.argv = [process.execPath, targetPath, ...process.argv.slice(2)];

const mod = new Module(targetPath, null);
mod.filename = targetPath;
mod.paths = Module._nodeModulePaths(path.dirname(targetPath));
mod._compile(code, targetPath);
NODE_THIEN
}

ensure_logs() {
  mkdir -p "$LOG_DIR"
}


identity_block() {
  cat <<'IDENTITY'
THIÊN OPERATOR IDENTITY
role      : runtime operator / architectural executor
identity  : not namespace, not protocol, not transport
mission   : giữ cổng, chạy gate, soi lệch tầng, bảo toàn runtime
oath      : không tự ý đồng nhất HTTP với identity; không bulk mutate khi chưa có gate
law       : ground truth > memory > report > wording
seal      : tools/thiên
IDENTITY
}

cmd_whoami() {
  banner
  identity_block
}

cmd_oath() {
  cat <<'OATH'
THIÊN OPERATOR OATH

1. Tôi không thay thế Gatekeeper.
2. Tôi không biến transport thành identity.
3. Tôi không rename hàng loạt khi chưa có evidence.
4. Tôi không coi report mạnh hơn ground truth.
5. Tôi không để runtime PASS nếu gate FAIL.
6. Tôi giữ boundary: anc://, .sira, tools/thiên, http://, SmartLink.
7. Tôi chỉ vận hành khi có trace, evidence, commit.
OATH
}

cmd_identity() {
  local file="$ROOT/docs/runtime/THIEN_OPERATOR_IDENTITY_20260425.si"
  if [ -f "$file" ]; then
    cat "$file"
  else
    identity_block
  fi
}

cmd_self() {
  cmd_whoami
  say ""
  cmd_oath
  say ""
  cmd_status
}


cmd_routes() {
  banner
  cat <<'ROUTES'
Canonical routes:
  anc://core     -> http://core.sira
  anc://audit    -> http://audit.sira
  anc://tam      -> http://tam.sira
  anc://nauion   -> http://nauion.sira
  anc://apps     -> http://apps.sira
  anc://docs     -> http://docs.sira
  anc://mach     -> http://mach.sira/mach/heyna

Human routes:
  apps    : http://apps.sira
  audit   : http://audit.sira
  tam     : http://tam.sira
  screens : http://tam.sira/__screens
  nauion  : http://nauion.sira
  core    : http://core.sira/api/health
ROUTES
}

cmd_health() {
  curl -sS --max-time 3 http://core.sira/api/health
  say ""
}

cmd_status() {
  banner
  say "PORT 80 LISTENER:"
  sudo lsof -nP -iTCP:80 -sTCP:LISTEN 2>/dev/null || say "NO LISTENER ON PORT 80"
  say ""
  say "PID FILE:"
  if [ -f "$PID_FILE" ]; then
    say "PID: $(cat "$PID_FILE")"
  else
    say "NO PID FILE: $PID_FILE"
  fi
  say ""
  say "HEALTH:"
  cmd_health || true
  say ""
  say "GIT:"
  git status --short || true
}

cmd_restart() {
  ensure_logs
  cd "$ROOT"

  if [ -f "$PID_FILE" ]; then
    sudo kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
  fi

  sudo env NATT_ROOT="$ROOT" NATT_PORT="$PORT" sh -c 'cd "$NATT_ROOT" && nohup ./tools/thiên run tools/natt_domain_gateway.sira "$NATT_PORT" > logs/natt_domain_gateway_80.log 2>&1 & echo $! > logs/natt_domain_gateway_80.pid'
  sleep 1

  curl -sS --max-time 3 http://core.sira/api/health | grep -q '"ok": true'

  say "RESTARTED: SIRA browser adapter"
  say "PID: $(cat "$PID_FILE")"
}

cmd_stop() {
  cd "$ROOT"
  if [ -f "$PID_FILE" ]; then
    sudo kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
    say "STOPPED: SIRA browser adapter"
  else
    say "NO PID FILE: $PID_FILE"
  fi
}

cmd_log() {
  ensure_logs
  if [ -f "$LOG_FILE" ]; then
    tail -80 "$LOG_FILE"
  else
    say "NO LOG FILE: $LOG_FILE"
  fi
}

cmd_open() {
  local target="${1:-apps}"
  case "$target" in
    apps) open "http://apps.sira" ;;
    audit) open "http://audit.sira" ;;
    tam) open "http://tam.sira" ;;
    screens) open "http://tam.sira/__screens" ;;
    nauion) open "http://nauion.sira" ;;
    core) open "http://core.sira/api/health" ;;
    all)
      open "http://apps.sira"
      open "http://audit.sira"
      open "http://tam.sira"
      open "http://tam.sira/__screens"
      open "http://nauion.sira"
      ;;
    *)
      say "ERR: unknown open target: $target" >&2
      exit 1
      ;;
  esac
  say "OPENED: $target"
}

cmd_resolve() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    say "Usage: tools/thiên resolve <name>" >&2
    exit 1
  fi
  curl -sS --max-time 3 "http://anc.sira/api/resolve?uri=anc://$name"
  say ""
}

cmd_emit() {
  local type="${1:-}"
  local payload="${2:-{}}"

  if [ -z "$type" ]; then
    say "Usage: tools/thiên emit <type> [json_payload]" >&2
    exit 1
  fi

  node - "$type" "$payload" <<'NODE_EMIT' | curl -sS --max-time 5 -X POST http://core.sira/api/events/emit -H "Content-Type: application/json" -d @-
const type = process.argv[2];
let payload = {};
try { payload = JSON.parse(process.argv[3] || "{}"); }
catch { payload = { raw: process.argv[3] || "" }; }

process.stdout.write(JSON.stringify({
  type,
  cell: "thien-operator-cell",
  payload
}));
NODE_EMIT
  say ""
}

cmd_doctor() {
  cmd_whoami
  say ""
  run_sira tools/validate_runtime_gate.sira --write-evidence
  say ""
  cmd_status
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help) usage ;;
  whoami) cmd_whoami ;;
  identity) cmd_identity ;;
  oath) cmd_oath ;;
  self) cmd_self ;;
  routes) cmd_routes ;;
  gate) run_sira tools/validate_runtime_gate.sira --write-evidence "$@" ;;
  doctor) cmd_doctor ;;
  status) cmd_status ;;
  health) cmd_health ;;
  restart) cmd_restart ;;
  stop) cmd_stop ;;
  log|logs) cmd_log ;;
  open) cmd_open "${1:-apps}" ;;
  namespace) run_sira tools/validate_sira_namespace.sira "$@" ;;
  browser) run_sira tools/validate_sira_browser_adapter.sira "$@" ;;
  transport) run_sira tools/validate_browser_transport_boundary.sira "$@" ;;
  ts-adapter) run_sira tools/validate_sira_ts_translation_adapter.sira "$@" ;;
  ts-plan) run_sira tools/sira_ts_translation_adapter.sira plan "$@" ;;
  resolve) cmd_resolve "${1:-}" ;;
  emit) cmd_emit "${1:-}" "${2:-{}}" ;;
  serve) run_sira tools/natt_domain_gateway.sira "${1:-80}" ;;
  run)
    if [ "$#" -lt 1 ]; then
      say "Usage: tools/thiên run <file.sira> [...args]" >&2
      exit 1
    fi
    run_sira "$@"
    ;;
  *.sira) run_sira "$cmd" "$@" ;;
  *)
    say "ERR: unknown command: $cmd" >&2
    say "" >&2
    usage >&2
    exit 1
    ;;
esac
