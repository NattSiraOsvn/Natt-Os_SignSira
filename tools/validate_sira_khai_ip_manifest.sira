#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const root = process.cwd();
const file = path.join(root, "docs", "runtime", "sira_khai_ip_manifest_20260425.na");
const preflight = path.join(root, "docs", "runtime", "sira_khai_ip_preflight_evidence_20260425.na");
const activeResolver = path.join(root, "docs", "runtime", "sira_active_resolver_ground_truth_20260425.na");
const corednsPlan = path.join(root, "docs", "runtime", "sira_coredns_zone_implementation_plan_20260425.na");

const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

function host(name) {
  return name + "." + "sira";
}

function ns() {
  return "." + "sira";
}

function isLanIp(ip) {
  return /^192\.168\.\d{1,3}\.\d{1,3}$/.test(ip) ||
         /^10\.\d{1,3}\.\d{1,3}\.\d{1,3}$/.test(ip) ||
         /^172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}$/.test(ip);
}

if (!fs.existsSync(file)) {
  errors.push("missing sira khai ip manifest");
} else {
  const raw = fs.readFileSync(file, "utf8");
  const data = JSON.parse(raw);
  const k = data.khai_ip || {};
  const edges = k.edges || {};
  const local = edges.local_edge || {};
  const lan = edges.lan_edge || {};
  const vpn = edges.vpn_edge || {};
  const pub = edges.public_edge || {};

  must(k.version === "v1.0", "invalid manifest version");
  must(k.namespace === ns(), "namespace must match sovereign namespace");
  must(k.production_edge_node === "imac", "production edge node must be imac");
  must(k.dns_engine === "coredns", "dns engine must be coredns");
  must(k.gateway_required === "yes", "gateway required");
  must(k.route_gate_required === "yes", "route gate required");
  must(k.sirasign_frame_guard_required === "yes", "sirasign frame guard required");

  must(local.resolver_ip === "127.0.0.1", "local resolver ip must be 127.0.0.1");
  must(local.gateway_ip === "127.0.0.1", "local gateway ip must be 127.0.0.1");
  must(local.status === "observed", "local edge must remain observed");

  must(isLanIp(lan.resolver_ip), "lan resolver ip must be private lan ip");
  must(lan.resolver_ip === lan.gateway_ip, "lan resolver and gateway ip must match current imac edge");
  must(lan.status === "declared_pending_external_smoke", "lan edge must be declared pending external smoke");
  must(Array.isArray(lan.required_smoke), "lan required smoke must be array");
  must(lan.required_smoke.length >= 5, "lan required smoke must include resolver and gateway checks");

  must(vpn.status === "not_declared", "vpn edge must not be declared yet");
  must(pub.status === "not_declared", "public edge must not be declared yet");

  [host("apps"), host("mach"), host("core"), host("audit"), host("render"), host("tam")].forEach(h => {
    must(k.allowed_logical_hosts.includes(h), "missing allowed logical host: " + h);
  });

  [host("unknown"), host("mail"), host("smtp"), host("imap")].forEach(h => {
    must(k.denied_logical_hosts.includes(h), "missing denied logical host: " + h);
  });

  [
    "dns la ten",
    "khai ip la dia chi song",
    "gateway la cong kiem",
    "route gate la luat vao",
    "sirasign la dau xac thuc frame",
    "no wildcard allow",
    "no admin route exposure",
    "no secret route exposure",
    "no direct audit write exposure",
    "no render seal exposure"
  ].forEach(rule => must(k.policy.includes(rule), "missing khai ip policy: " + rule));

  [
    "status: applied",
    "production-ready",
    "wildcard -> allow",
    "allow wildcard",
    "bypass gateway",
    "public_edge_enabled"
  ].forEach(mark => must(!raw.includes(mark), "forbidden khai ip wording: " + mark));
}

must(fs.existsSync(preflight), "missing khai ip preflight evidence");
must(fs.existsSync(activeResolver), "missing active resolver ground truth");
must(fs.existsSync(corednsPlan), "missing coredns zone implementation plan");

if (errors.length) {
  console.error("sira khai ip manifest validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira khai ip manifest validation: pass");
console.log("file=docs/runtime/sira_khai_ip_manifest_20260425.na");
