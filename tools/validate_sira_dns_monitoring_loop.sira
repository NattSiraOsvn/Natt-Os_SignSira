#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sira_dns_monitoring_loop_evidence_20260426.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing dns monitoring loop evidence");
} else {
  const c = fs.readFileSync(file, "utf8");
  const lower = c.toLowerCase();

  [
    "sira dns monitoring loop evidence",
    "status: monitoring-loop-observed",
    "wired_edge: 192.168.1.199",
    "wifi_edge: 192.168.1.238",
    "primary_edge: wired_edge",
    "primary_fail_count: 0",
    "allow_latency_avg_ms:",
    "dns-monitoring-loop-pass",
    "primary wired_edge dns returned expected records"
  ].forEach(clause => must(c.includes(clause), "missing monitoring clause: " + clause));

  [
    "curl",
    "safari",
    "browser adapter",
    "transport smoke",
    "runtime smoke",
    "wildcard -> allow",
    "allow wildcard",
    "production-ready"
  ].forEach(mark => must(!lower.includes(mark), "forbidden monitoring wording: " + mark));
}

if (errors.length) {
  console.error("sira dns monitoring loop validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira dns monitoring loop validation: pass");
console.log("file=docs/runtime/sira_dns_monitoring_loop_evidence_20260426.na");
