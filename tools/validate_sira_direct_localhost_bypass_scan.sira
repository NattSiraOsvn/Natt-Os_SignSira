#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sira_direct_localhost_bypass_scan_20260425.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing direct localhost bypass scan");
} else {
  const c = fs.readFileSync(file, "utf8");
  const requiredClauses = [
  "sira direct localhost bypass scan",
  "status: read-only-scan",
  "direct localhost bypass",
  "unknown.sira",
  "forbidden path phải deny",
  "localhost hoặc 127.0.0.1 chỉ được dùng làm transport target",
  "bypass test matrix",
  "bước sau mới là smoke runner hoặc gateway patch"
];
  const forbiddenMarks = [
  "DNS XONG",
  "http là identity",
  "dns là authority",
  "PASS",
  "FAIL"
];

  for (const clause of requiredClauses) {
    must(c.includes(clause), "missing clause: " + clause);
  }

  for (const mark of forbiddenMarks) {
    must(!c.includes(mark), "forbidden surface leak: " + mark);
  }
}

if (errors.length) {
  console.error("sira direct localhost bypass scan validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira direct localhost bypass scan validation: pass");
console.log("file=docs/runtime/sira_direct_localhost_bypass_scan_20260425.na");
