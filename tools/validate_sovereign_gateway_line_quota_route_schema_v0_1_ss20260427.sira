#!/usr/bin/env node
const fs = require("fs");

const file = "docs/runtime/sovereign_gateway_line_quota_route_schema_v0_1_ss20260427.na";
const text = fs.readFileSync(file, "utf8");

const must = [
"@scope sovereign-gateway line quota route sirasign audit",
"@runtime_scope excluded",
"Không chạm nattos.sh.",
"Line model",
"Quota model",
"Route model",
"Server khách edge node",
"Máy trạm sensor/IoT",
"Audit event",
"SiraSign",
".anc",
"resolver-profile",
"red_zone_access",
"gateway.route.checked",
"Gate 1 pass condition"
];

const forbidden = [
"production-ready",
".com là lõi bắt buộc",
".zone là lõi bắt buộc",
"hosting provider là bắt buộc",
"mail provider là bắt buộc"
];

let errors = [];

for (const s of must) {
if (!text.includes(s)) errors.push("missing required fragment: " + s);
}

for (const s of forbidden) {
if (text.includes(s)) errors.push("forbidden wording: " + s);
}

if (errors.length) {
console.error("sovereign gateway line quota route schema validation: fail");
for (const e of errors) console.error(" - " + e);
process.exit(1);
}

console.log("sovereign gateway line quota route schema validation: pass");
console.log("file=" + file);
