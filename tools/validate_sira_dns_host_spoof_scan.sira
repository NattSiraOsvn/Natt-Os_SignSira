#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sira_dns_host_spoof_scan_20260425.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing sira dns host spoof scan");
} else {
  const c = fs.readFileSync(file, "utf8");
  const requiredClauses = [
  "sira dns host spoof scan",
  "status: read-only-scan",
  "tools/natt_domain_gateway.sira",
  "docs/runtime/sira_dns_zone_manifest_20260425.na",
  "host spoof",
  "unknown .sira",
  "direct localhost bypass",
  "scan này chưa sửa gateway implementation",
  "possible risk patterns"
];

  for (const clause of requiredClauses) {
    must(c.includes(clause), "missing clause: " + clause);
  }

  [
    "DNS XONG",
    "http là identity",
    "dns là authority",
    "PASS",
    "FAIL"
  ].forEach(mark => {
    must(!c.includes(mark), "forbidden surface leak: " + mark);
  });
}

if (errors.length) {
  console.error("sira dns host spoof scan validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira dns host spoof scan validation: pass");
console.log("file=docs/runtime/sira_dns_host_spoof_scan_20260425.na");
