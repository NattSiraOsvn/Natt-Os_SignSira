#!/usr/bin/env node
const fs = require("fs");
const path = require("path");

const file = path.join(process.cwd(), "docs", "runtime", "sira_wired_edge_firewall_audit_evidence_20260426.na");
const errors = [];

function must(cond, msg) {
  if (!cond) errors.push(msg);
}

if (!fs.existsSync(file)) {
  errors.push("missing wired edge firewall audit evidence");
} else {
  const c = fs.readFileSync(file, "utf8");
  const lower = c.toLowerCase();

  [
    "sira wired edge firewall audit evidence",
    "status: firewall-audit-observed",
    "wired_edge_ip: 192.168.1.199",
    "dns_port: 53",
    "dns_engine: coredns",
    "listener evidence",
    "dns udp smoke on wired edge",
    "dns tcp smoke on wired edge",
    "denied host smoke",
    "pf firewall readout",
    "macos application firewall readout",
    "decision: firewall-audit-pass",
    "router reservation must keep 192.168.1.199 mapped to en0 mac"
  ].forEach(clause => must(c.includes(clause), "missing firewall audit clause: " + clause));

  [
    "curl",
    "safari",
    "browser adapter",
    "transport smoke",
    "runtime smoke",
    "wildcard -> allow",
    "allow wildcard",
    "production-ready"
  ].forEach(mark => must(!lower.includes(mark), "forbidden firewall audit wording: " + mark));
}

if (errors.length) {
  console.error("sira wired edge firewall audit validation: fail");
  for (const e of errors) console.error(" - " + e);
  process.exit(1);
}

console.log("sira wired edge firewall audit validation: pass");
console.log("file=docs/runtime/sira_wired_edge_firewall_audit_evidence_20260426.na");
