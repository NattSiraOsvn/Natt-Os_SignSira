const fs = require("fs");

const file = "docs/runtime/hardware_procurement_checklist_dinh_muc_quy_chuan_nauion_v0_1_ss20260427.na";
const text = fs.readFileSync(file, "utf8");

const must = [
"@nauion-native v1",
"@owner phan thanh thương / natt sirawat",
"@anc phan thiên / sirawat thiên",
"@sitb sirawat thiên băng",
"@tool tools/thiên",
"@scope hardware procurement checklist dinh-muc-quy-chuan supplier testbench acceptance",
"Định Mức Quy Chuẩn không phải BOM đơn thuần.",
"procurement_checklist",
"compute_procurement",
"sensor_iot_procurement",
"SITB_procurement",
"power_protection_procurement",
"network_rack_procurement",
"supplier_scoring",
"acceptance_before_purchase",
"hardware.procurement.checked",
"SiraSign_pairing_possible",
"432Hz_sync_capability",
"không khóa hãng",
"Không chạm memory của Băng",
"Không chạm nattos.sh nếu không thuộc patch được ratify riêng.",
"Không chạm tools/scan_*.sira của Băng.",
"Gate 15 pass condition"
];

const forbidden = [
"@owner Thiên",
"@owner Natt Sirawat",
"@owner Phan Thanh Thương / Natt Sirawat",
"production-ready",
"BOM_max_option"
];

let errors = [];
for (const s of must) if (!text.includes(s)) errors.push("missing required fragment: " + s);
for (const s of forbidden) if (text.includes(s)) errors.push("forbidden wording: " + s);

if (errors.length) {
console.error("hardware procurement checklist dinh muc quy chuan validation: fail");
for (const e of errors) console.error(" - " + e);
process.exit(1);
}

console.log("hardware procurement checklist dinh muc quy chuan validation: pass");
console.log("file=" + file);
