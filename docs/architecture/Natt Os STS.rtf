\uc0\u9474    \u9500 \u9472 \u9472  normalizers/         # Chu\u7849 n h\'f3a th\'f4ng minh\
\uc0\u9474    \u9474    \u9500 \u9472 \u9472  schema-detector.ts   # T\u7921  \u273 \u7897 ng ph\'e1t hi\u7879 n c\u7845 u tr\'fac\
