mach.onopen = () => console.log('Nahere — mach[C5:RN_KEEP_RIME] song[C1:RN_KEEP_RIME]');
mach.onmessage = (e) => {
  const data = JSON.parse(e.data);
  // data.event = ten[C0:RN_KEEP_RIME] su[C5:RN_KEEP_RIME] kien[C5:RN_KEEP_RIME]
  // data.payload = du[C4:RN_KEEP_RIME] lieu[C5:RN_KEEP_RIME]
  // data.ts = timestamp
};
mach.onerror = () => console.warn('Mach[C5:RN_KEEP_RIME] dut[C1:RN_KEEP_RIME] — dung[C2:RN_KEEP_RIME] Whao fallback');

// Whao fallback — poll mau[C4:RN_OI_AU] 3s
setInterval(async () => {
  const r = await fetch('http://localhost:3001/kenh/vet');
  const d = await r.json();
  // xu[C3:RN_KEEP_RIME] ly[C1:RN_KEEP_RIME] d.events
}, 3000);
