## §4. API CONTRACT — qiint2.engine.ts

```typescript
// src/core/qiint2/qiint2.engine.ts (NEW FILE, Bang scope)
export interface Qiint2CalibrationParams {
  tolerance_bridge_v2: number;           // §3.1
  recovery_potential_weights: number[];  // §3.2 [6 weights]
  sigma_u_octave: number;                // §3.3
  beta_n_per_cycle: number;              // §3.4
  dos_thresholds: [number, number, number]; // §3.5 [tier1, tier2, tier3]
  M_persona_weights: [number, number, number]; // §3.6
  sigma_qneu_log_octave: number;         // §3.7
  snapshot_tau_decay_min: number;        // §3.8
  
  // Metadata
  calibration_source: 'GUESSED' | 'MEASURED';
  measured_at: string | null;
  measurement_data_source: string | null;
}

export interface Qiint2Engine {
  getParams(): Qiint2CalibrationParams;
  measureParam(paramId: keyof Qiint2CalibrationParams, dataSource: string): Promise<number | number[]>;
  updateParam(paramId: string, value: number | number[], evidence: string): void;
  
  // Butterfly effect defense API
  checkCascadeRisk(currentLoad: SystemLoad): CascadeRiskLevel;
  getSurvivalThresholds(): [number, number, number]; // For K1 consumption
}

export type CascadeRiskLevel = 'SAFE' | 'WATCH' | 'BACKPRESSURE' | 'LOAD_SHED' | 'CIRCUIT_BREAK';
```

**Implementation owner:** Bang (per session 20260424 delegation)

**Default state:** All params `calibration_source: 'GUESSED'` at scaffold. Phase 2 calibration update from real data.

