## 1. Format layout

```
┌────────────────────────────────────────────────────────────────┐
│ [MAGIC      4B ] "NATT" (0x4E 0x41 0x54 0x54)                  │
│ [VERSION    2B ] uint16 BE — 0x0100 = v1.0                     │
│ [HDR_LEN    4B ] uint32 BE                                     │
│ [HEADER     var] plaintext JSON — identity + KDF meta          │
│ [MAN_LEN    4B ] uint32 BE                                     │
│ [MANIFEST   var] AES-256-GCM(JSON, key, nonce_man)             │
│ [BODY_LEN   8B ] uint64 BE                                     │
│ [BODY       var] AES-256-GCM(tar.zst, key, nonce_body)         │
│ [GCM_TAG    16B] GCM authentication tag over HEADER+MAN+BODY   │
│ [END_MAGIC  4B ] "TTAN"                                        │
└────────────────────────────────────────────────────────────────┘
```

### 1.1 HEADER plaintext schema
```json
{
  "$nauion": "NATT-v1.0",
  "kind": "ColonyPack",
  "magic": "NATT",
  "version": "1.0",
  "packed_at": "2026-04-20T21:30:00.000Z",
  "packed_by": "bang@natt-os_verANC",
  "gatekeeper": "Phan Thanh Thương",
  "colony_id": "natt-os_verANC",
  "branch": "feat/p1.3-file-extension-validator",
  "head_hash": "d24086c",
  "flavor": "for-kim",
  "content_scope": ["src/", "governance/", "governance/memory/kim/", "audit/reports/"],
  "excludes": [".git/", "node_modules/", "_deprecated/", "database/ctytam/"],
  "kdf": {
    "algo": "pbkdf2-sha256",
    "iterations": 100000,
    "salt_hex": "a1b2c3d4e5f60708a9b0c1d2e3f40506",
    "key_inputs": [
      "canonical_phả_hệ (embedded in tool)",
      "sha256_body_of(governance/HIEN-PHAP-Natt-OS-v5.0.anc)"
    ]
  },
  "encryption": {
    "algo": "aes-256-gcm",
    "nonce_manifest_hex": "...",
    "nonce_body_hex": "..."
  },
  "compression": {
    "algo": "zstd",
    "level": 19
  },
  "total_files": 1552,
  "total_bytes_uncompressed": 52428800,
  "total_bytes_compressed": 12345678
}
```

