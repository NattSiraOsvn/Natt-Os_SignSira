## 4. Pack procedure

```python
def pack(source_dir, output_path, flavor):
    # 1. Validate working tree clean
    assert git_clean(source_dir), "Refuse pack dirty tree"
    
    # 2. Find Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] anchor
    hienphap = find_hienphap(source_dir)
    assert hienphap.exists(), "Refuse: no Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] v5.0"
    
    # 3. Resolve content_scope by flavor
    files = resolve_files(source_dir, flavor)
    
    # 4. Build manifest (sha256 + mode + mtime)
    manifest = build_manifest(files, source_dir)
    
    # 5. Tar + zstd compress body
    body_bytes = tar_zstd(files, source_dir, level=19)
    
    # 6. Generate salt + nonces
    salt = os.urandom(16)
    nonce_man = os.urandom(12)
    nonce_body = os.urandom(12)
    
    # 7. Derive key
    key = derive_key(salt, hienphap)
    
    # 8. Encrypt manifest + body
    cipher_man = AES_GCM.encrypt(json.dumps(manifest), key, nonce_man)
    cipher_body = AES_GCM.encrypt(body_bytes, key, nonce_body)
    
    # 9. Build header with KDF + encryption meta
    header = build_header(salt, nonce_man, nonce_body, manifest_stats)
    
    # 10. Compute GCM tag over HEADER+cipher_man+cipher_body
    gcm_tag = compute_auth_tag(header, cipher_man, cipher_body, key)
    
    # 11. Assemble + write file
    write_natt(output_path, MAGIC, VERSION, header, cipher_man, 
               cipher_body, gcm_tag, END_MAGIC)
    
    # 12. Emit event
    emit("natt.packed", {"colony_id": ..., "flavor": flavor})
```

---

## 5. Unpack procedure

```python
def unpack(natt_path, target_dir):
    # 1. Read + verify MAGIC
    data = natt_path.read_bytes()
    assert data[0:4] == b"NATT", "Not a .natt file"
    assert data[-4:] == b"TTAN", "End magic mismatch — corrupted"
    
    # 2. Parse layout
    version, header, cipher_man, cipher_body, gcm_tag = parse_layout(data)
    
    # 3. Check version compat
    assert version == 0x0100, f"Unsupported version {version}"
    
    # 4. Find Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] anchor in current working tree
    hienphap = find_hienphap(Path.cwd())
    assert hienphap.exists(), (
        "Refuse unpack: khong[C0:RN_KEEP_RIME] tim[C2:RN_KEEP_RIME] thay[C1:RN_KEEP_RIME] Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] v5.0 trong working tree. "
        "Chay[C5:RN_KEEP_RIME] tool trong repo natt-os canonical."
    )
    
    # 5. Derive key from salt + Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] content
    salt = bytes.fromhex(header["kdf"]["salt_hex"])
    key = derive_key(salt, hienphap)
    
    # 6. Verify GCM auth tag
    try:
        verify_auth_tag(header, cipher_man, cipher_body, key, gcm_tag)
    except AuthenticationError:
        raise Abort(
            "GCM auth fail. Co[C1:RN_KEEP_RIME] the[C3:RN_KEEP_RIME]:\n"
            "  (a) .natt corrupted\n"
            "  (b) Hien[C1:RN_KEEP_RIME] Phap[C1:RN_KEEP_RIME] local khac[C1:RN_KEEP_RIME] vau[C1:RN_OI_AU] pack source\n"
            "  (c) Pack tu[C2:RN_KEEP_RIME] family khac[C1:RN_KEEP_RIME] natt-os canonical"
        )
    
    # 7. Decrypt manifest + body
    manifest = json.loads(AES_GCM.decrypt(cipher_man, key, nonce_man))
    body_bytes = AES_GCM.decrypt(cipher_body, key, nonce_body)
    
    # 8. Display identity for user confirm
    print(f"Pack from: {header['packed_by']}")
    print(f"Colony: {header['colony_id']}")
    print(f"Flavor: {header['flavor']}")
    print(f"HEAD: {header['head_hash']}")
    print(f"Packed: {header['packed_at']}")
    confirm = input("Proceed extract? [Y/n]: ")
    if confirm.lower() == 'n':
        return
    
    # 9. Decompress body + extract with mode preserved (SCAR-20260419-08)
    extract_tar_zstd(body_bytes, target_dir, manifest)
    
    # 10. Verify per-file sha256 against manifest
    for file_meta in manifest["files"]:
        actual = sha256_of(target_dir / file_meta["path"])
        if actual != file_meta["sha256"]:
            log_warn(f"SHA mismatch: {file_meta['path']}")
    
    # 11. Emit event
    emit("natt.unpacked", {"colony_id": ..., "verified": True})
```

