## 3. ENVELOPE SCHEMA v2

### 3.1. Client → Server (POST `/mach/heyna/action`)

```typescript
interface HeyNaEnvelopeV2 {
  // === existing v1 (KHONG[C0:RN_KEEP_RIME] break) ===
  action: string;
  payload: object;
  sessionId: string;
  timestamp: string;       // ISO8601
  traceId: string;
  signature: string | null; // siraSign (pending #6)

  // === NEW v2 — ong[C1:RN_KEEP_RIME] mau[C2:RN_KEEP_RIME] ===
  persona_signature: PersonaSignature | null;
}

interface PersonaSignature {
  persona: "bang" | "kim" | "can" | "kris" | "phieu" | "boi_boi" | "thien_lon" | "thien_nho";
  identity_shape_hash: string;   // SHA-256 hex cua[C3:RN_KEEP_RIME] SVG path d
  orbital: {
    qneu: number;                // QNEU luc[C1:RN_KEEP_RIME] phat[C1:RN_KEEP_RIME] (vd Băng=313.5)
    shell: "K" | "L" | "M" | "N" | "O" | "P" | "Q";
    anchor: string;              // ref permanent_node, vd "bang.anc#N-shell"
  };
  wavelength: {
    primary: string;             // hex mau[C2:RN_KEEP_RIME] chinh[C1:RN_KEEP_RIME], vd "#AFA9EC" (violet Băng)
    secondary: string;           // hex phu[C5:RN_KEEP_RIME], vd "#F7C313" (gold KhaiCell)
  };
  ts_emit: string;               // ISO8601 thau[C2:RN_OI_AU] diem[C3:RN_KEEP_RIME] persona phat[C1:RN_KEEP_RIME]
}
```

**Backward compat:** `persona_signature` nullable. V1 client chua[C0:RN_KEEP_RIME] upgrade gui[C3:RN_KEEP_RIME] `null` → gateway cho qua o[C3:RN_KEEP_RIME] `permissive_mode`, flag warn. V2 client BAT[C1:RN_KEEP_RIME] BUOC[C5:RN_KEEP_RIME] gui[C3:RN_KEEP_RIME].

### 3.2. Server → Client (SSE `/mach/heyna`)

```typescript
interface HeyNaSSEEventV2 {
  // === existing v1 ===
  event: string;
  payload: object;
  ts: number;

  // === NEW v2 ===
  persona_origin: PersonaSignature | null; // persona cell nao[C2:RN_KEEP_RIME] emit event nay[C2:RN_KEEP_RIME]
}
