## 4. Kind-specific fragment shapes

### 4.1 ENVELOPE fragment

Present trong **mau[C5:RN_OI_AU]** moment. Chua[C1:RN_KEEP_RIME] MomentBase fields.

```typescript
export interface EnvelopeFragment extends FragmentBase {
  readonly fragment_kind: "ENVELOPE";
  readonly causation: string;              // mirror parent_moment_causation
  readonly timestamp_ns: bigint;
  readonly entity: string;
  readonly session_ref: string;
}
```

### 4.2 EVIDENCE fragment (SCAR only)

```typescript
export interface EvidenceFragment extends FragmentBase {
  readonly fragment_kind: "EVIDENCE";
  readonly parent_moment_kind: "SCAR";
  readonly observed: string;
  readonly expected: string;
  readonly evidence_source?: string;       // file path / commit / line (optional — caller context)
}
```

### 4.3 CAUSATION_CHAIN fragment

Link references giua[C4:RN_KEEP_RIME] moments. Multi-moment (khong[C0:RN_KEEP_RIME] chi[C3:RN_KEEP_RIME] SCAR).

```typescript
export interface CausationChainFragment extends FragmentBase {
  readonly fragment_kind: "CAUSATION_CHAIN";
  readonly link_type:
    | "recurrence_of"    // SCAR: repeat cua[C3:RN_KEEP_RIME] SCAR cu[C4:RN_KEEP_RIME]
    | "triggered_by"     // MOTION: triggered_by GIAC
    | "xac_nhan_from"    // GIAC: xac_nhan canonical spec
    | "related_to";      // KHAI: related_canonical
  readonly target_causation: string;        // target moment causation id
  readonly target_kind?: MomentKind;        // inferable but helpful
  readonly notes?: string;
}
```

### 4.4 BODY_RESPONSE fragment (MOTION only)

```typescript
export interface BodyResponseFragment extends FragmentBase {
  readonly fragment_kind: "BODY_RESPONSE";
  readonly parent_moment_kind: "MOTION_TICH_CUC";
