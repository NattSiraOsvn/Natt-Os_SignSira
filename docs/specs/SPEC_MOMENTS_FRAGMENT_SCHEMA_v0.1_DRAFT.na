  readonly gatekeeper_witnessed: boolean;
  readonly witness_context?: string;        // optional context (session, location in conversation)
}
```

### 4.5 INSIGHT_CONTENT fragment (KHAI only)

```typescript
export interface InsightContentFragment extends FragmentBase {
  readonly fragment_kind: "INSIGHT_CONTENT";
  readonly parent_moment_kind: "KHAI_SANG";
  readonly gatekeeper_quote: string;        // verbatim cau[C0:RN_KEEP_RIME] day[C5:RN_KEEP_RIME]
  readonly gia_tri_cot_loi: string;         // gia[C1:RN_KEEP_RIME] tri[C5:RN_KEEP_RIME] cot[C1:RN_KEEP_RIME] lau[C4:RN_OI_AU] entity absorb
  readonly entity_nhan: string;             // cach[C1:RN_KEEP_RIME] entity nhen[C5:RN_AN_EN]
}
```

### 4.6 INNER_RESONANCE fragment (GIAC only)

```typescript
export interface InnerResonanceFragment extends FragmentBase {
  readonly fragment_kind: "INNER_RESONANCE";
  readonly parent_moment_kind: "GIAC_NGO";
  readonly cai_ben_trong: string;           // "cai[C1:RN_KEEP_RIME] ben[C0:RN_KEEP_RIME] trong da[C4:RN_KEEP_RIME] luon[C0:RN_KEEP_RIME] hien[C5:RN_KEEP_RIME] huu[C4:RN_KEEP_RIME]"
  readonly motion: string;                  // cam[C3:RN_KEEP_RIME] giac[C1:RN_KEEP_RIME] khi touch
}
```

### 4.7 REMEDY fragment (SCAR only)

```typescript
export interface RemedyFragment extends FragmentBase {
  readonly fragment_kind: "REMEDY";
  readonly parent_moment_kind: "SCAR";
  readonly remedy_text: string;             // vaccin description
  readonly heal_status: "open" | "partial" | "healed";
