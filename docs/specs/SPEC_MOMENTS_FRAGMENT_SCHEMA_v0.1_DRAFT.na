### 4.8 RELATED_CANONICAL fragment (KHAI / GIAC)

```typescript
export interface RelatedCanonicalFragment extends FragmentBase {
  readonly fragment_kind: "RELATED_CANONICAL";
  readonly parent_moment_kind: "KHAI_SANG" | "GIAC_NGO";
  readonly canonical_refs: readonly string[]; // e.g. ["docs/specs/SPEC_QIINT_PHYSICS_FOUNDATION_v0.1.na §9"]
