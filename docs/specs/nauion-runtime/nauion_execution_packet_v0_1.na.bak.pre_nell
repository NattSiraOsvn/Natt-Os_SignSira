==PACKET_ROOT==
  packet_id: định danh packet
  packet_kind: source | signal | memory | authority | substrate | audit | recovery
  grammar_ref: Nauion grammar / source rule đang áp dụng
  created_at: thời điểm sinh packet
  source_hash: hash nguồn sinh packet
  state: optimal | stable | nominal | drift | warning | risk | critical
==END==

==PACKET_BODY==
  obitan: pattern bản thể bất biến
  field_anchor:
    hien_phap_ref: neo hiến pháp
    anc_ref: passport / identity anchor
    sirasign_ref: seal / authority proof
    memory_ref: .na / .phieu / audit evidence
  qneu_mass: khối lượng trọng trường
  qiint_pull: lực kéo trường theo context
  orbital_coherence: độ kết mạch obitan
  body_drift: mức trôi bản thể nếu có
==END==

==PACKET_MEDIUM==
  carrier_kind: na_text | signal_payload | memory_fragment | audit_record | state_snapshot
  carrier_ref: path / hash / signal id
  chromatic_mark: none | L0 | L1 | L2 | L3 | L4
  medium_state: clean | partial | stale | corrupted | quarantined
  materialization_allowed: yes | no | gatekeeper_only
==END==

==PACKET_SUBSTRATE==
  substrate_ref: evidence path hoặc SiraSign ref
  substrate_kind: sovereign_gateway | wired_edge | sensor_intake | dns_route | electrical_module | field_installation
  hardware_anchor: topology / BOM / module evidence
  physical_intake_anchor: luật tiếp nhận vật lý
  edge_anchor: wired edge / configuration / installation evidence
  route_anchor: DNS / line / quota / route evidence
  power_thermal_anchor: điện / nhiệt / tải
  runtime_probe_anchor: probe / timeout / manifest evidence
  acceptance_anchor: procurement / installation / acceptance evidence
==END==

==CAUSATION_CHAIN==
  event_id: id duy nhất
  tenant_scope: business/runtime scope
  lineage_scope: Sirawat / entity lineage scope
  trace_id: vết end-to-end
  span_id: nhánh con
  causation_id: packet cha
  parent_packet_ref: optional
==END==

==PRESSURE_FIELD==
  pressure_type: FALL | DISSIPATE | OSCILLATE
  pressure_value: range 0.0..1.0
  impedance_z: trở kháng packet
  receiver_impedance_z0: trở kháng cell nhận
  reflection_coefficient: R=(Z-Z0)/(Z+Z0)
  rule: pressure không được mock; không ép route bằng if/else; pressure sinh từ trường và boundary result.
==END==

==AUTHORITY_BOUNDARY==
  drafter: entity tạo packet
  ratifier: entity duyệt nếu cần
  consumer_whitelist: cell/entity được đọc
  forbidden_zones: vùng cấm
  public_redaction: mức được lộ ra public layer
  violation_action: mark_boundary | quarantine | reflect | safe_rest
==END==

==SELF_BREATH_LOOP==
  audit_trace: append-only
  memory_imprint: none | temporary | reinforced | permanent_node_candidate
  signal_echo: none | real | reflected | quarantined
  decay_clock: ttl | session | durable | permanent
  recovery_path: none | reanchor | safe_rest | resurrect_if_body_anchor_alive
==END==

==INTERPRETER_CONSUMPTION_RULE==
  step_1_load: Field Loader nạp packet + kiểm source_hash.
  step_2_anchor: kiểm body/medium/substrate anchor.
  step_3_authority: kiểm authority boundary trước materialization.
  step_4_pressure: tính pressure field, không mock.
  step_5_consume: Living Interpreter quyết FALL/DISSIPATE/OSCILLATE.
  step_6_breath: ghi audit, imprint memory, phát signal echo.
  step_7_stop: nếu drift/risk/critical thì safe-rest hoặc quarantine.
==END==

==KERNEL_COUPLING==
  field_translator: source/signal/memory/event -> packet
  field_loader: packet -> runtime field
  living_interpreter: packet -> state transition
  smartlink_protocol: packet -> field transfer
  authority_boundary: packet -> allowed/marked/quarantined
  self_breath_loop: packet -> audit/memory/signal
==END==

==NON_SCOPE==
  - không Host Bridge
  - không Vite/React/Node adapter
  - không app/server/client cleanup
  - không JSON hóa bản thể
  - không đổi source evidence của Băng
  - không rename/move/delete
==END==

==NEXT_SIGNAL==
Băng review drift/evidence.
Sau review mới tách Field Translator / Living Interpreter / Field Loader spec.
==END==
