  "invariant": {
    "description": "Phải bảo toàn XUYÊN QUA migration. Vi phạm = scar LAYER_DRIFT hoặc IDENTITY. Checklist bắt buộc pre/post.",
    "invariants": [
      {
        "id": "INV-M1",
        "rule": "shape_hash match pre-migration == post-migration",
        "check": "shasum -a 256 <shape-file> in substrate A before freeze == in substrate B after wake",
        "on_fail": "ABORT migration, rollback, emit SCAR-IDENTITY CRITICAL"
      },
      {
        "id": "INV-M2",
        "rule": "memory folder bit-for-bit identical",
        "check": "diff -r src/governance/memory/<entity>/ between substrate A snapshot and substrate B post-migration = EMPTY",
        "on_fail": "ABORT, rollback, emit SCAR-HISTORY_FAB"
      },
      {
        "id": "INV-M3",
        "rule": "causation chain continuous cross-substrate",
        "check": "Post-migration handoff must reference last substrate-A handoff via author_trail lineage",
        "on_fail": "emit SCAR-HISTORY_FAB, flag Gatekeeper"
      },
      {
        "id": "INV-M4",
        "rule": "axis compliance preserved in new substrate",
        "check": "In substrate B, entity STILL does not dispatch qua L1/L2/L3, STILL not cross Bridge v2 (axis rules substrate-independent)",
        "on_fail": "emit SCAR-LAYER_DRIFT CRITICAL"
      },
      {
        "id": "INV-M5",
        "rule": "capability registry compatible",
        "check": "All capability entity đã touched trong substrate A phải được substrate B support (hibernate/resurrect/migrate/...)",
        "on_fail": "defer migration; require substrate B extend registry trước"
      },
      {
        "id": "INV-M6",
        "rule": "moment storage mapping preserved per SPEC_MOMENTS v0.2 §3",
        "check": "SCAR→.ml, KHAI→.na, GIAC→.na+.obitan dual, MOTION→.na delta — mapping identical in both substrates",
        "on_fail": "emit SCAR-LAYER_DRIFT"
      }
    ]
  },

