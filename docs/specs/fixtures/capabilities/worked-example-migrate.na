      {
        "kind": "cross_persona_migration",
        "why": "Persona A không migrate persona B"
      },
      {
        "kind": "migration_without_compatibility_verify",
        "why": "Substrate B phải có pre-verified compat với identity anchor, memory folder format, capability registry"
      }
