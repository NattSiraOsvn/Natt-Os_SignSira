const FIBER_DECAY_IDLE_MS      = 7 * 24 * 60 * 60 * 1000
const FIBER_DECAY_RATE_BASE    = 0.10
const FIBER_DECAY_K            = 0.2
const FIBER_LOST_THRESHOLD     = 0.20   // fiberLost (hysteresis low)
const FIBER_DISSOLVE_THRESHOLD = 0.05   // xoa[C1:RN_KEEP_RIME] TouchRecord
// FIBER_THRESHOLD = 5 da[C4:RN_KEEP_RIME] co[C1:RN_KEEP_RIME] (fiberFormed tai[C5:RN_KEEP_RIME] sensitivity ≥ 0.75)
```

