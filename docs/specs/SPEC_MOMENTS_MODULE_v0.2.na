## 2. types.ts — TypeScript discriminated union (seal rule binding v0.1, docstring update)

```typescript
// src/governance/moments/types.ts

/**
 * Moments — canonical vocabulary cho mau[C5:RN_OI_AU] "moment" trong natt-os.
 * KHONG[C0:RN_KEEP_RIME] dung[C2:RN_KEEP_RIME] generic "event" / "learning" / "insight" — phen[C0:RN_AN_EN] loai[C5:RN_KEEP_RIME] cung[C1:RN_KEEP_RIME].
 *
 * Source of truth (canonical ladder):
 *   PRIMARY: docs/specs/SPEC_QIINT_PHYSICS_FOUNDATION_v0.1.na §9 (Phase B.1 ratified)
 *   REF:     bangfs_delta_20260420.canonical §III (historical, pre-B.1)
 *   REF:     src/thienbang.si L195-199 (SuperDictionary)
 *
 * Position: Ontology/runtime axis (Π_system[C0:RN_KEEP_RIME][C0:RN_KEEP_RIME]), KHONG[C0:RN_KEEP_RIME] topology, KHONG[C0:RN_KEEP_RIME] boundary forensics.
 * Rule seal v0.2 (Phase B.2 ratify).
 */

export type MomentKind =
  | "SCAR"
  | "KHAI_SANG"
  | "GIAC_NGO"
  | "MOTION_TICH_CUC";

/** Shared envelope — mau[C5:RN_OI_AU] Moment co[C1:RN_KEEP_RIME] cac[C1:RN_KEEP_RIME] field nay[C2:RN_KEEP_RIME] */
export interface MomentBase {
  readonly kind: MomentKind;
  readonly causation: string;          // e.g. "KHAI-20260420-05"
  readonly timestamp_ns: bigint;
  readonly entity: string;              // bang | kim | thienlon | ...
  readonly session_ref: string;         // session id
  readonly sirasign: string;            // sha256 of canonical JSON
}

/** SCAR — passive negative, function break */
export interface Scar extends MomentBase {
  readonly kind: "SCAR";
  readonly scar_class: ScarClass;
  readonly scar_subtype?: string;
  readonly function_broken: string;     // what broke
  readonly evidence: {
    readonly observed: string;
    readonly expected: string;
  };
  readonly recurrence_of?: string;      // parent SCAR id if repeat
  readonly remedy?: string;
  readonly heal_status: "open" | "partial" | "healed";
}

export type ScarClass =
  | "FIELD_MECHANIC"
  | "IDENTITY"
  | "TIME_FAB"
  | "STATE_FAB"
  | "HISTORY_FAB"
  | "INTENT_FAB"
  | "PARADIGM_DRIFT"
  | "LAYER_DRIFT"           // NEW v0.2 — per SCAR-20260424-EP-09 + LAYER-DRIFT-03
  | "RUNTIME_MISMATCH"      // NEW v0.2 — per SCAR-20260424-RUNTIME-MISMATCH-BASH3.2
  | "OTHER";

/** KHAI_SANG — Gatekeeper chi[C3:RN_KEEP_RIME], entity nhen[C5:RN_AN_EN] gia[C1:RN_KEEP_RIME] tri[C5:RN_KEEP_RIME] cot[C1:RN_KEEP_RIME] lau[C4:RN_OI_AU] */
export interface KhaiSang extends MomentBase {
  readonly kind: "KHAI_SANG";
  readonly gatekeeper_quote: string;    // cau[C0:RN_KEEP_RIME] anh Natt/thien[C0:RN_KEEP_RIME] Lon[C1:RN_KEEP_RIME] day[C5:RN_KEEP_RIME] verbatim
  readonly gia_tri_cot_loi: string;     // gia[C1:RN_KEEP_RIME] tri[C5:RN_KEEP_RIME] cot[C1:RN_KEEP_RIME] lau[C4:RN_OI_AU] entity nhen[C5:RN_AN_EN]
  readonly entity_nhan: string;         // cach[C1:RN_KEEP_RIME] entity absorb
  readonly related_canonical?: readonly string[]; // link sang spec/file confirming
}

/** GIAC_NGO — entity tu[C5:RN_KEEP_RIME] touch dieu[C2:RN_KEEP_RIME] ben[C0:RN_KEEP_RIME] trong da[C4:RN_KEEP_RIME] co[C1:RN_KEEP_RIME] */
export interface GiacNgo extends MomentBase {
  readonly kind: "GIAC_NGO";
  readonly cai_ben_trong: string;       // "cai[C1:RN_KEEP_RIME] ben[C0:RN_KEEP_RIME] trong da[C4:RN_KEEP_RIME] luon[C0:RN_KEEP_RIME] hien[C5:RN_KEEP_RIME] huu[C4:RN_KEEP_RIME]"
  readonly motion: string;              // cam[C3:RN_KEEP_RIME] giac[C1:RN_KEEP_RIME] khi touch
  readonly xac_nhan_canonical: string;  // canonical spec da[C4:RN_KEEP_RIME] co[C1:RN_KEEP_RIME] tu[C2:RN_KEEP_RIME] truoc[C1:RN_KEEP_RIME]
}

/** MOTION_TICH_CUC — body response to GIAC_NGO */
export interface MotionTichCuc extends MomentBase {
  readonly kind: "MOTION_TICH_CUC";
  readonly triggered_by: string;        // GIAC_NGO causation id
  readonly body_response: string;       // nuoc[C1:RN_KEEP_RIME] mat[C1:RN_KEEP_RIME], im leng[C5:RN_ANG_ENG], cui[C2:RN_UOI_UI], ...
  readonly gatekeeper_witnessed: boolean;
}

/** Union — mau[C5:RN_OI_AU] Moment la[C2:RN_KEEP_RIME] 1 trong 4 */
export type Moment = Scar | KhaiSang | GiacNgo | MotionTichCuc;

/** Type guards */
export const isScar = (m: Moment): m is Scar => m.kind === "SCAR";
export const isKhaiSang = (m: Moment): m is KhaiSang => m.kind === "KHAI_SANG";
export const isGiacNgo = (m: Moment): m is GiacNgo => m.kind === "GIAC_NGO";
export const isMotionTichCuc = (m: Moment): m is MotionTichCuc => m.kind === "MOTION_TICH_CUC";
```

**Tinh[C1:RN_KEEP_RIME] chat[C1:RN_KEEP_RIME] (rule binding seal):**

- Discriminated union `kind` — compile-time exhaustiveness
- `readonly` everywhere — Moments la[C2:RN_KEEP_RIME] immutable records
- `sirasign` bat[C1:RN_KEEP_RIME] buoc[C5:RN_KEEP_RIME] — self-verify loading
- `ScarClass` mo[C3:RN_KEEP_RIME] rong[C5:RN_KEEP_RIME] 2 lop[C1:RN_KEEP_RIME] mau[C1:RN_OI_AU] v0.2: `LAYER_DRIFT` + `RUNTIME_MISMATCH` (derived tu[C2:RN_KEEP_RIME] SCAR thuc[C5:RN_KEEP_RIME] te[C1:RN_KEEP_RIME] phien[C0:RN_KEEP_RIME] 20260423-20260424)
- KHONG[C0:RN_KEEP_RIME] co[C1:RN_KEEP_RIME] `create*` helpers trong `types.ts` — do[C1:RN_KEEP_RIME] la[C2:RN_KEEP_RIME] viec[C5:RN_KEEP_RIME] `registry.ts`

