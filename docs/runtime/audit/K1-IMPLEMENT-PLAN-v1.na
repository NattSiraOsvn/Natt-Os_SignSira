### §2.4 STEP 4 — TotalSignal monitor loop

**Add to ChromaticStateEngine:**

```typescript
private startTotalSignalMonitor(): void {
  setInterval(() => {
    const totalSignal = this.thresholdEngine.getTotalSignal();
    
    // Emit survival-cell state based on TotalSignal
    let survivalLevel: ChromaticLevel = 'nominal';
    if (totalSignal >= 4.0) survivalLevel = 'critical';
    else if (totalSignal >= 2.5) survivalLevel = 'risk';
    else if (totalSignal >= 1.2) survivalLevel = 'warning';
    else if (totalSignal >= 0.5) survivalLevel = 'drift';
    
    this.eventBus.emit('survival.gate', {
      action: survivalLevel === 'critical' ? 'LOAD_SHED' :
              survivalLevel === 'risk'     ? 'BACKPRESSURE' :
              survivalLevel === 'warning'  ? 'BACKPRESSURE' :
              'ACCEPT',
      totalSignal,
      level: survivalLevel,
      timestamp: new Date().toISOString(),
    });
  }, 5000); // 5s tick
}
```

### §2.5 STEP 5 — QuantumBuffer feed queue depth

**File to edit:** `src/core/quantum/quantum-buffer.engine.ts` L65 (getQueueLength)

**Add emit:**

```typescript
public getQueueLength() {
  const len = this.queue.length;
  eventBus.emit('cell.metric', {
    cell: 'survival-cell',
    metric: 'total_queue_depth',
    value: len,
  });
  return len;
}
```

