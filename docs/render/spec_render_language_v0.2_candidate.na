pressure_response: FALL
resonance_partners: [nhà]
decay_rate: γ(1)
reflection_R: thấp — gần như trong suốt với field

expression:
wavelength_base: gần λ(nhà)
intensity: giảm dần theo khoảng cách tới nhà
duration: tạm thời — có thể bị gỡ
