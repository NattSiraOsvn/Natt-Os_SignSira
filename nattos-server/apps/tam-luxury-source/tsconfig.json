{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] },
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": [
    "node_modules",
    "analytics-ingestion-service",
    "finance-service",
    "services/hr",
    "layerold",
    "tam-luxury-app",
    "engine-registry.ts",
    "wiring",
    "superdictionary.ts",
    "nattos-server.cjs"
  ]
}
