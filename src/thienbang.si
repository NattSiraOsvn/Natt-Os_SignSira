      tuDich: giải
      tuNell: giai
      nghia: giải cấu trúc dữ liệu
      vi: hệ bóc cấu trúc để hiểu nội dung
      carrier: parse
      polarity: NORMAL

  opsec:
    - key: REDACT_TRACE
      tuCu: redact trace
      tuDich: che vết
      tuNell: chevet
      nghia: che vết nhạy cảm
      vi: hệ che dấu nhạy cảm trước khi ra ngoài
      carrier: redact
      polarity: INVERTED
    - key: HASH_TRACE
      tuCu: hash evidence
      tuDich: băm vết
      tuNell: bamvet
      nghia: băm bằng chứng
      vi: hệ thay raw bằng hash để đối chiếu
      carrier: hash
      polarity: NORMAL
    - key: CUT_EXPOSURE
      tuCu: remove exposure
      tuDich: cắt lộ
      tuNell: catlo
      nghia: cắt phần lộ
      vi: hệ cắt phần có nguy cơ lộ topology
      carrier: redact
      polarity: INVERTED
    - key: HIDE_TOPOLOGY
      tuCu: hide topology
      tuDich: giấu tuyến
      tuNell: giautuyen
      nghia: giấu topology
      vi: hệ không để lộ sơ đồ sống ra public
      carrier: hide
      polarity: INVERTED
    - key: METRIC_ONLY
      tuCu: metric only
      tuDich: chỉ số
      tuNell: chiso
      nghia: chỉ xuất chỉ số
      vi: hệ chỉ đưa số đếm và hash thay raw
      carrier: metric
      polarity: NORMAL
    - key: CLAIM_BOUNDARY
      tuCu: claim boundary
      tuDich: khóa claim
      tuNell: khoaclaim
      nghia: khóa ranh claim
      vi: hệ chặn claim vượt bằng chứng
      carrier: claim
      polarity: NORMAL

  git_state:
    - key: SEE_BRANCH
      tuCu: branch/status
      tuDich: nhìn nhánh
      tuNell: nhinnhanh
      nghia: xem nhánh hiện tại
      vi: hệ nhìn mình đang ở nhánh nào
      carrier: git branch
      polarity: NORMAL
    - key: CHECK_WORKTREE
      tuCu: status
      tuDich: soát sân
      tuNell: soatsan
      nghia: xem sân làm việc
      vi: hệ soát các thay đổi đang tồn tại
      carrier: git status
      polarity: NORMAL
    - key: STAGE_ARTIFACT
      tuCu: git add
      tuDich: gắn
      tuNell: gan
      nghia: gắn artifact vào chốt
      vi: hệ gắn artifact đúng scope để chuẩn bị chốt
      carrier: git add
      polarity: NORMAL
    - key: UNSTAGE_ARTIFACT
      tuCu: git reset staged
      tuDich: tháo
      tuNell: thao
      nghia: tháo artifact khỏi sân chốt
      vi: hệ tháo vật ra khỏi chốt nhưng không phá thân
      carrier: git reset
      polarity: INVERTED
    - key: COMMIT_STATE
      tuCu: git commit
      tuDich: chốt
      tuNell: chot
      nghia: chốt trạng thái thành mốc
      vi: hệ chốt một trạng thái có dấu và có lời khai
      carrier: git commit
      polarity: NORMAL
    - key: PUSH_STATE
      tuCu: git push
      tuDich: đẩy
      tuNell: day
      nghia: đẩy chốt ra ngoài
      vi: hệ đẩy mốc đã chốt lên vùng chia sẻ
      carrier: git push
      polarity: NORMAL
    - key: FETCH_STATE
      tuCu: git fetch
      tuDich: kéo
      tuNell: keo
      nghia: kéo ảnh ngoài về
      vi: hệ kéo trạng thái ngoài về để đối chiếu
      carrier: git fetch
      polarity: NORMAL
    - key: PICK_COMMIT
      tuCu: cherry-pick
      tuDich: bứng
      tuNell: bung
      nghia: bứng một chốt riêng
      vi: hệ bứng riêng một mốc mà không kéo cả dòng ngoài scope
      carrier: git cherry-pick
      polarity: NORMAL


  system_container_file_lifecycle:
    - key: MAKE_CONTAINER
      tuCu: mkdir
      tuDich: dựng
      tuNell: dung
      nghia: dựng vùng chứa
      vi: hệ dựng một vùng chứa để artifact có nơi trú
      carrier: mkdir
      polarity: NORMAL
    - key: ENSURE_CONTAINER
      tuCu: mkdir -p
      tuDich: dựng chắc
      tuNell: dungchac
      nghia: bảo đảm vùng chứa tồn tại
      vi: hệ dựng vùng chứa nếu chưa có và không phá nếu đã có
      carrier: mkdir -p
      polarity: NORMAL
    - key: TOUCH_ARTIFACT
      tuCu: touch
      tuDich: chạm
      tuNell: cham
      nghia: tạo dấu hiện diện cho artifact
      vi: hệ chạm để tạo artifact rỗng hoặc cập nhật dấu thời gian
      carrier: touch
      polarity: NORMAL
    - key: EMPTY_ARTIFACT
      tuCu: truncate
      tuDich: trống
      tuNell: trong
      nghia: làm rỗng artifact nhưng giữ thân
      vi: hệ xoá nội dung bên trong nhưng vẫn giữ vật mang
      carrier: truncate
      polarity: INVERTED
    - key: COPY_ARTIFACT
      tuCu: cp
      tuDich: sao
      tuNell: sao
      nghia: sao artifact
      vi: hệ tạo bản sao của artifact để giữ hoặc chuyển
      carrier: cp
      polarity: NORMAL
    - key: MOVE_ARTIFACT
      tuCu: mv
      tuDich: dời
      tuNell: doi
      nghia: dời hoặc đổi tên artifact
      vi: hệ dời artifact sang vị trí hoặc tên mới
      carrier: mv
      polarity: NORMAL
    - key: REMOVE_ARTIFACT
      tuCu: rm
      tuDich: gỡ
      tuNell: go
      nghia: gỡ artifact
      vi: hệ gỡ artifact khỏi mặt làm việc
      carrier: rm
      polarity: INVERTED
    - key: RESTORE_ARTIFACT
      tuCu: restore
      tuDich: hồi
      tuNell: hoi
      nghia: hồi artifact từ nguồn đúng
      vi: hệ hồi artifact từ ground truth hoặc remote được chỉ định
      carrier: git restore
      polarity: NORMAL
    - key: BACKUP_ARTIFACT
      tuCu: backup
      tuDich: giữ bản
      tuNell: giuban
      nghia: giữ bản dự phòng
      vi: hệ giữ bản dự phòng trước khi nắn hoặc vá
      carrier: cp
      polarity: NORMAL
    - key: CHECK_ARTIFACT_EXISTS
      tuCu: test -f/test -d
      tuDich: xét có
      tuNell: xetco
      nghia: xét artifact có tồn tại không
      vi: hệ xét vật mang có thật trong nhà trước khi thao tác
      carrier: test
      polarity: NORMAL
    - key: LIST_CONTAINER
      tuCu: ls/find
      tuDich: bày
      tuNell: bay
      nghia: bày danh sách trong vùng chứa
      vi: hệ bày các artifact trong vùng chứa để kiểm
      carrier: ls/find
      polarity: NORMAL
    - key: SEAL_LIFECYCLE
      tuCu: lifecycle seal
      tuDich: khóa vòng
      tuNell: khoavong
      nghia: khóa vòng đời artifact
      vi: hệ khóa trạng thái vòng đời sau khi artifact đủ điều kiện
      carrier: seal
      polarity: NORMAL

$polarity_rule:
  NORMAL: bật, hiện, cho qua, gắn, chốt, đẩy, kéo
  INVERTED: tắt, ẩn, chặn, gỡ, tháo, cách ly, bọc, cắt lộ
  mirror: C0 đổi C7, C1 đổi C6, C2 đổi C5, C3 đổi C4

$discipline:
  - Không nói awk tạo báo cáo.
  - Nói rút trường bằng carrier awk.
  - Không nói sed sửa báo cáo.
  - Nói nắn dòng bằng carrier sed.
  - Không nói echo xuất câu.
  - Nói vang dòng bằng carrier echo.
  - Từ điển gốc phải có dấu để người đọc hiểu.
  - Runtime hoặc surface có thể dùng tuNell không dấu theo luật riêng.

$seal:
  sentence: Carrier được mượn; động từ nền phải thuộc Natt Nell; từ điển gốc phải có dấu.
  sign: Phan Thanh Thương / Natt Sirawat
==NELL_PRIMITIVE_WORDS_V0_1_END==