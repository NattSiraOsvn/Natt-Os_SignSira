  // ── 04. NAUION LANGUAGE & MOMENTS (Ngôn Ngữ Nauion & Nhận Thức) ───────────
  "ANOMALY_RESONANCE":      "Cộng hưởng bất thường — Hiện tượng nhiều tế bào cùng báo lỗi ở một tần số, dự báo sập hệ thống.",
  "AURA":                   "Aura (Trường ảo) — Phản ánh độ ổn định (Health Status) của tế bào NATT_CELL.",
  "AWAKENING":              "Awakening (Sự thức tỉnh) — Khoảnh khắc bừng tỉnh của hệ, Z-index đột ngột về mức 1.0 sau nhiễu loạn.",
  "AWARENESS_SPARK":        "Tia lửa nhận thức — Tín hiệu chớp nhoáng báo hiệu Entity bắt đầu hiểu context mới.",
