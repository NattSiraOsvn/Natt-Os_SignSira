# === LANGUAGE SPINE VOCAB v0.1 BEGIN ===
## LANGUAGE SPINE VOCAB v0.1
## auto-derived from dialect_rules_v0_1.na + protected_tokens_v0_1.na

dialect_rules:
- RB_UOI_U | ns=rime | prefix=RB | from=ươi | to=ư | idx=1
- RN_UOI_UI | ns=rime | prefix=RN | from=uoi | to=ui | idx=2
- R_TONE_ONLY | ns=tone | prefix=R | from=same_rime | to=same_rime | idx=3
- R_PROTECTED | ns=protected | prefix=R | from=protected_token | to=identity | idx=4

protected_tokens:
- NATT-OS | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- HeyNa | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- KhaiCell | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
