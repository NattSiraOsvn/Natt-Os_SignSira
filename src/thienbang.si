- .na | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- .bang | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- .phieu | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- .sira | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
- IDENTITY_SHAPE_HASH | rule=R_PROTECTED | tone=CTRL_ESCAPE | color=C6 | protected=true
