      polarity: NORMAL
    - key: SEAL_STATE
      tuCu: seal/lock
      tuDich: khóa
      tuNell: khoa
      nghia: khóa trạng thái
      vi: hệ khóa một trạng thái thành mốc có hiệu lực
      carrier: seal
      polarity: NORMAL
    - key: UNLOCK_STATE
      tuCu: unlock
      tuDich: mở khóa
      tuNell: mokhoa
      nghia: mở khóa có kiểm soát
      vi: hệ mở trạng thái đã khóa khi có quyền
      carrier: unlock
      polarity: NORMAL
    - key: QUARANTINE_ARTIFACT
      tuCu: quarantine
      tuDich: cách ly
      tuNell: cachly
      nghia: cách ly artifact rủi ro
      vi: hệ đưa vật nghi vấn ra vùng riêng để không lan
      carrier: quarantine
      polarity: INVERTED

  runtime_state:
    - key: WRITE_MEMORY
      tuCu: memory write
      tuDich: nhớ
      tuNell: nho
      nghia: ghi ký ức
      vi: hệ ghi điều cần giữ vào .na
