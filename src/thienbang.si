==NELL_PRIMITIVE_WORDS_V0_1_START==
$nauion: NELL_PRIMITIVE_WORDS-v0.1
$role: PRIMITIVE_VERB_DICTIONARY
$owner: NaUion-Server
$status: CANONICAL_CANDIDATE

$principle:
  carrier_may_be_external: true
  primitive_semantic_must_be_nell: true
  dictionary_first: true
  lowercase_surface: true
  polarity_cipher_aware: true

$field_shape:
  key: mã máy đọc dạng UPPER_SNAKE_CASE
  tuCu: carrier ngoài hoặc từ cũ
  tuDich: từ dịch tiếng Việt có dấu
  tuNell: từ Nell sau chuyển ngữ, dùng cho runtime/surface
  nghia: nghĩa tiếng Việt có dấu
  vi: diễn giải nội hệ bằng tiếng Việt có dấu
  carrier: công cụ có thể mượn
  polarity: NORMAL / INVERTED / NONE

$primitive_groups:

  read_write:
    - key: ECHO_LINE
      tuCu: echo/printf
      tuDich: vang
      tuNell: vang
      nghia: phát dòng hoặc tín hiệu ra mặt hiện
      vi: hệ vang một dòng ra surface để người đọc thấy
      carrier: printf
      polarity: NORMAL
    - key: OPEN_BODY
      tuCu: cat/head/tail
      tuDich: mở
      tuNell: mo
      nghia: mở thân artifact để đọc
      vi: hệ mở thân file hoặc artifact để lấy nội dung
      carrier: cat
      polarity: NORMAL
    - key: WRITE_BODY
      tuCu: redirect/write
      tuDich: ghi
      tuNell: ghi
      nghia: ghi nội dung vào artifact
      vi: hệ ghi nội dung thành một vật mang mới
      carrier: redirect
      polarity: NORMAL
    - key: APPEND_BODY
      tuCu: append
      tuDich: nối
      tuNell: noi
      nghia: nối thêm nội dung vào cuối artifact
      vi: hệ nối dòng mới vào thân cũ mà không xoá thân cũ
      carrier: append
      polarity: NORMAL
    - key: COPY_BODY
      tuCu: cp
      tuDich: sao
      tuNell: sao
      nghia: sao artifact sang nơi khác
      vi: hệ tạo bản sao của một vật mang
      carrier: cp
      polarity: NORMAL
    - key: MOVE_BODY
      tuCu: mv
      tuDich: dời
      tuNell: doi
      nghia: dời hoặc đổi tên artifact
      vi: hệ dời vị trí hoặc tên gọi của vật mang
      carrier: mv
      polarity: NORMAL
    - key: REMOVE_BODY
      tuCu: rm
      tuDich: gỡ
      tuNell: go
      nghia: gỡ artifact khỏi mặt hiện
      vi: hệ gỡ vật mang khỏi surface làm việc
      carrier: rm
      polarity: INVERTED
    - key: TRUNCATE_BODY
      tuCu: truncate
      tuDich: trống
      tuNell: trong
      nghia: làm rỗng artifact nhưng giữ thân
      vi: hệ xoá nội dung bên trong nhưng vẫn giữ vật mang
      carrier: truncate
      polarity: INVERTED

  search_extract:
    - key: FIND_ARTIFACT
      tuCu: find
      tuDich: mò
      tuNell: mo
      nghia: mò artifact trong nhà
      vi: hệ mò vật cần tìm từ trong cấu trúc nhà
      carrier: find
      polarity: NORMAL
    - key: MATCH_EVIDENCE
      tuCu: grep
      tuDich: soi
      tuNell: soi
      nghia: soi dấu trong artifact
      vi: hệ soi dấu vết để biết có bằng chứng hay không
      carrier: grep
      polarity: NORMAL
    - key: EXTRACT_FIELD
      tuCu: awk/cut
      tuDich: rút
      tuNell: rut
      nghia: rút trường hoặc đoạn cần dùng
      vi: hệ rút phần đúng trong một dòng hoặc một bảng
      carrier: awk
      polarity: NORMAL
    - key: SHAPE_LINE
      tuCu: sed
      tuDich: nắn
      tuNell: nan
      nghia: nắn dòng theo luật
      vi: hệ nắn dòng cũ thành dạng mới đúng rule
      carrier: sed
      polarity: NORMAL
    - key: FILTER_SIGNAL
      tuCu: pipe/filter
      tuDich: lọc
      tuNell: loc
      nghia: lọc tín hiệu theo điều kiện
      vi: hệ giữ phần đúng và bỏ phần lệch
      carrier: pipe
      polarity: NORMAL
    - key: COUNT_EVIDENCE
      tuCu: wc
      tuDich: đếm
      tuNell: dem
      nghia: đếm dòng, file hoặc dấu vết
      vi: hệ đếm bằng chứng để định lượng trạng thái
      carrier: wc
      polarity: NORMAL
    - key: ORDER_EVIDENCE
      tuCu: sort
      tuDich: xếp
      tuNell: xep
      nghia: xếp lại thứ tự bằng chứng
      vi: hệ xếp dấu vết để đọc theo thứ tự ổn định
      carrier: sort
      polarity: NORMAL
    - key: DEDUPE_EVIDENCE
      tuCu: uniq
      tuDich: khử
      tuNell: khu
      nghia: khử trùng lặp
      vi: hệ khử dấu vết bị lặp để tránh nhiều giả
      carrier: uniq
      polarity: NORMAL

  proof_guard:
    - key: HASH_EVIDENCE
      tuCu: shasum/hash
      tuDich: ấn
      tuNell: an
      nghia: ấn dấu chứng cứ
