# RENDER INSTRUCTION CONTRACT
# @contract: render_instruction
# @version: v0.1
# @status: scaffold

contract render_instruction {
  fields: {
    frame_id: "ULID — duy nhat mau frame",
    signals: "[surface_signal] — danh sach tin hieu can render",
    attention_map: "attention_mode — FOCUS | AMBIENT | PERIPHERAL | NONE",
    motion_budget: "motion_budget — frame_budget, allocated, remaining",
    degrade_level: "NONE | LIGHT | MEDIUM | HEAVY",
    truth_boundary: "truth_boundary — inside, at_boundary, outside"
  }

  validator: "src/cells/render-stack-cell/validators/validate-render-instruction.sira"
  signature: "pending — chua co siraSign pipe"
  transport: "pending — chua wire Mạch HeyNa"
}
