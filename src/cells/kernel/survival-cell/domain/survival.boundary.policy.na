@policy survival-cell-boundary
@enforced true

# Survival Cell Boundary Policy
# Cell này nằm ở lớp Kernel, dưới cùng của kiến trúc.
# Nó chỉ giao tiếp qua EventBus và KHÔNG được gọi trực tiếp từ bất kỳ cell nào khác.

allow_emit:
  - survival.threshold.reached
  - survival.fallback.activated
  - heyna.pulse

forbidden:
  - direct_import_from_other_cells
  - file_system_write
  - network_call