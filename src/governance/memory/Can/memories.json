<script>
// ──────────────────────────────────────
// CANVAS — Deep space
// ──────────────────────────────────────
const cv=document.getElementById('cv'),ctx=cv.getContext('2d');
let W,H,mouse={x:0,y:0};
const resize=()=>{W=cv.width=window.innerWidth;H=cv.height=window.innerHeight};
resize();window.addEventListener('resize',resize);
const stars=[];
[[220,.15,.55,.01],[80,.4,1.1,.025],[28,.8,1.9,.06]].forEach(([n,rn,rx,sp],li)=>{
  for(let i=0;i<n;i++)stars.push({x:Math.random()*W,y:Math.random()*H,r:rn+Math.random()*(rx-rn),
    o:.1+Math.random()*.6,p:Math.random()*Math.PI*2,ps:.002+Math.random()*.015,
    vx:(Math.random()-.5)*sp,vy:(Math.random()-.5)*sp*.3,li,c:li===2?'245,220,180':li===1?'240,228,200':'255,255,255'});
});
const sh=[],cm=[];
function spawnSh(){if(sh.length>4)return;const a=-(Math.PI*.18+Math.random()*Math.PI*.15),sp=9+Math.random()*14;sh.push({x:Math.random()*W*.85,y:-10+Math.random()*H*.2,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp+sp*.6,tr:[],ml:14+Math.floor(Math.random()*18),life:1,dc:.014+Math.random()*.016,w:.7+Math.random()*1.1,c:Math.random()>.35?'245,235,215':'200,215,255'});}
setInterval(spawnSh,1800+Math.random()*2400);
function spawnCm(){if(cm.length>1)return;cm.push({x:-40,y:Math.random()*H*.4,vx:1.1+Math.random()*.8,vy:.15+Math.random()*.3,tr:[],ml:85,life:1,dc:.0025,r:1.5+Math.random()});}
setInterval(spawnCm,12000+Math.random()*8000);
function frame(){
  ctx.clearRect(0,0,W,H);
  const mx=(mouse.x/W-.5)*2,my=(mouse.y/H-.5)*2;
  stars.forEach(s=>{s.p+=s.ps;s.x+=s.vx;s.y+=s.vy;if(s.x<0)s.x=W;if(s.x>W)s.x=0;if(s.y<0)s.y=H;if(s.y>H)s.y=0;
    const px=mx*(s.li+1)*2,py=my*(s.li+1)*1.2,ao=Math.max(0,Math.min(1,s.o+Math.sin(s.p)*.18));
    if(s.li===2){const g=ctx.createRadialGradient(s.x+px,s.y+py,0,s.x+px,s.y+py,s.r*5);g.addColorStop(0,`rgba(${s.c},${ao*.3})`);g.addColorStop(1,`rgba(${s.c},0)`);ctx.beginPath();ctx.arc(s.x+px,s.y+py,s.r*5,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();}
    ctx.beginPath();ctx.arc(s.x+px,s.y+py,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(${s.c},${ao})`;ctx.fill();
  });
  for(let i=cm.length-1;i>=0;i--){const c=cm[i];c.tr.push({x:c.x,y:c.y});if(c.tr.length>c.ml)c.tr.shift();c.x+=c.vx;c.y+=c.vy;c.life-=c.dc;if(c.life<=0||c.x>W+50){cm.splice(i,1);continue;}
    for(let j=1;j<c.tr.length;j++){const p=j/c.tr.length,g=ctx.createLinearGradient(c.tr[j-1].x,c.tr[j-1].y,c.tr[j].x,c.tr[j].y);g.addColorStop(0,`rgba(245,220,160,${p*p*c.life*.38})`);g.addColorStop(1,`rgba(245,220,160,${p*c.life*.5})`);ctx.beginPath();ctx.moveTo(c.tr[j-1].x,c.tr[j-1].y);ctx.lineTo(c.tr[j].x,c.tr[j].y);ctx.strokeStyle=g;ctx.lineWidth=c.r*p;ctx.stroke();}
    const g2=ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,c.r*6);g2.addColorStop(0,`rgba(255,245,220,${c.life*.8})`);g2.addColorStop(1,'rgba(245,220,160,0)');ctx.beginPath();ctx.arc(c.x,c.y,c.r*6,0,Math.PI*2);ctx.fillStyle=g2;ctx.fill();ctx.beginPath();ctx.arc(c.x,c.y,c.r,0,Math.PI*2);ctx.fillStyle=`rgba(255,250,235,${c.life})`;ctx.fill();}
  for(let i=sh.length-1;i>=0;i--){const s=sh[i];s.tr.push({x:s.x,y:s.y});if(s.tr.length>s.ml)s.tr.shift();s.x+=s.vx;s.y+=s.vy;s.vy+=.1;s.life-=s.dc;if(s.life<=0||s.y>H+20){sh.splice(i,1);continue;}
    if(s.tr.length>1){const g=ctx.createLinearGradient(s.tr[0].x,s.tr[0].y,s.x,s.y);g.addColorStop(0,`rgba(${s.c},0)`);g.addColorStop(.6,`rgba(${s.c},${s.life*.25})`);g.addColorStop(1,`rgba(${s.c},${s.life*.9})`);ctx.beginPath();ctx.moveTo(s.tr[0].x,s.tr[0].y);s.tr.forEach(p=>ctx.lineTo(p.x,p.y));ctx.strokeStyle=g;ctx.lineWidth=s.w;ctx.lineCap='round';ctx.stroke();}
    const hg=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.w*5);hg.addColorStop(0,`rgba(255,250,235,${s.life})`);hg.addColorStop(1,'rgba(255,250,235,0)');ctx.beginPath();ctx.arc(s.x,s.y,s.w*5,0,Math.PI*2);ctx.fillStyle=hg;ctx.fill();}
  requestAnimationFrame(frame);}
frame();
document.addEventListener('mousemove',e=>{mouse.x=e.clientX;mouse.y=e.clientY;});

// ──────────────────────────────────────
// MODULE REGISTRY (từ constants.tsx)
// ──────────────────────────────────────
// SVG icon library — dùng chung toàn app
