const GROUP_ORDER=['CORE','PRODUCTION','FINANCE','STRATEGIC','SYSTEM'];
const ROLE_MAP={CFO:'MASTER',CEO:'LEVEL_1',GENERAL_MANAGER:'LEVEL_2',ACCOUNTING_MANAGER:'LEVEL_8',PROD_DIRECTOR:'LEVEL_2',COLLABORATOR:'LEVEL_7'};
let currentRole='MASTER',currentView='dashboard';
let sbOpen=true;

function buildNav(){
  const nav=document.getElementById('sb-nav');nav.innerHTML='';
  GROUP_ORDER.forEach(grp=>{
    const mods=MODULES.filter(m=>m.group===grp&&m.id!=='command'&&(currentRole==='MASTER'||m.roles.includes(currentRole)));
    if(!mods.length)return;
    const g=document.createElement('div');g.className='sb-grp';
    if(sbOpen)g.innerHTML=`<div class="grp-lbl">${grp}</div>`;
    mods.forEach(m=>{
      const b=document.createElement('button');
      b.className='sb-btn'+(m.id===currentView?' active':'');
      b.id='nb-'+m.id;
      b.onclick=()=>nav2(m.id);
      const badge=getBadge(m.id);
      b.innerHTML=`<span class="si">${getIcon(m.id)}</span>${sbOpen?`<span class="sl">${m.title}</span>${badge?`<span class="sbg" style="${badge.style}">${badge.v}</span>`:''}${getStatusDot(m.id)?`<div class="dot-a" style="background:${getStatusDot(m.id)}"></div>`:''}`:''}`
      g.appendChild(b);
    });
    nav.appendChild(g);
    if(sbOpen){const d=document.createElement('div');d.className='sb-div';nav.appendChild(d);}
  });
}

function getBadge(id){
  const m={customs_intelligence:{v:'56 lô',style:'background:rgba(200,192,255,.1);color:var(--lav);border:1px solid rgba(200,192,255,.18)'},
    banking_processor:{v:'9,250',style:'background:rgba(143,255,212,.08);color:var(--mint);border:1px solid rgba(143,255,212,.16)'},
    warehouse:{v:'86.2t',style:'background:rgba(245,226,192,.07);color:var(--g1);border:1px solid rgba(245,226,192,.14)'},
    audit_trail:{v:'17 SC',style:'background:rgba(255,80,80,.07);color:var(--red);border:1px solid rgba(255,80,80,.14)'},
    cell_organism:{v:'38',style:'background:rgba(245,226,192,.07);color:var(--g1);border:1px solid rgba(245,226,192,.14)'},
  };
  return m[id]||null;
}
function getStatusDot(id){
  const m={sales_tax:'var(--red)',tax_reporting:'var(--red)',banking_processor:'var(--amber)'};
  return m[id]||null;
}

function nav2(id){
  currentView=id;
  document.querySelectorAll('.sb-btn').forEach(b=>b.classList.remove('active'));
  const nb=document.getElementById('nb-'+id);if(nb)nb.classList.add('active');
  document.getElementById('cmd-btn').classList.toggle('active',id==='command');
  // Show correct view
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  const specific=document.getElementById('view-'+id);
  if(specific){specific.classList.add('active');}
  else{
    const ph=document.getElementById('view-placeholder');
    ph.classList.add('active');
    document.getElementById('ph-title').textContent=MODULES.find(m=>m.id===id)?.title||id.toUpperCase();
  }
}
function nav(id){nav2(id);}

function toggleSb(){
  sbOpen=!sbOpen;
  const sb=document.getElementById('sb');
  sb.classList.toggle('collapsed',!sbOpen);
  document.getElementById('sblogo').style.display=sbOpen?'block':'none';
  document.getElementById('sbver').style.display=sbOpen?'block':'none';
  document.getElementById('cmd-lbl').style.display=sbOpen?'block':'none';
  document.getElementById('sb-foot').style.display=sbOpen?'block':'none';
  document.querySelector('.sb-toggle').textContent=sbOpen?'«':'»';
  buildNav();
}

function onRoleChange(v){
  currentRole=ROLE_MAP[v]||'LEVEL_5';
  const n={CFO:'MASTER NATT',CEO:'CEO',GENERAL_MANAGER:'Giám đốc',ACCOUNTING_MANAGER:'Kế toán',PROD_DIRECTOR:'GĐ Sản xuất',COLLABORATOR:'CTV'}[v];
  document.getElementById('hu-name').textContent=n||v;
  document.getElementById('hu-role').textContent=v+' · '+currentRole.split('(')[0].trim();
  const isMaster=currentRole==='MASTER';
  document.getElementById('hu-dot').style.cssText=isMaster?'width:8px;height:8px;border-radius:50%;background:var(--amber);box-shadow:0 0 10px rgba(255,190,80,.6)':'width:8px;height:8px;border-radius:50%;background:var(--ice);box-shadow:0 0 8px rgba(184,232,255,.5)';
  buildNav();
}

