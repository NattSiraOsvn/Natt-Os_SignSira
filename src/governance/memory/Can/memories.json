};
function h2r(h){const r=/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(h);return r?`${parseInt(r[1],16)},${parseInt(r[2],16)},${parseInt(r[3],16)}`:null}

function makeMedal(cell){
  const w=document.createElement('div');w.className='mw';w.onclick=()=>openModal(cell);
  const sc=cell.col,rgb=h2r(sc),glow=rgb?`rgba(${rgb},.4)`:'rgba(200,180,150,.3)';
  const pbr=`conic-gradient(from 0deg,#01010A,${sc}55,#02020C,rgba(255,255,255,.055),${sc}28,#01010A)`;
  const frOp=cell.tc*.8,irdCol=cell.sc>1?'rgba(255,80,80,.28)':cell.sc===1?'rgba(255,160,80,.22)':'rgba(200,180,255,.16)';
  const caFilt=cell.ac>.7?'url(#cfh)':'url(#cfl)';
  const orbOp=Math.min(.55,cell.cn*.055);
  const R=33,circ=2*Math.PI*R,dash=(cell.q*circ).toFixed(1),gap=(circ-cell.q*circ).toFixed(1);
  w.innerHTML=`
  <div class="mb">
    <div class="orb">
      <svg class="o1" viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" fill="none" stroke="${sc}" stroke-width="${.2+cell.cn*.015}" stroke-dasharray="2 ${Math.max(2,10-cell.cn*.4)}" opacity="${orbOp*1.4}"/></svg>
      <svg class="o2" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="${sc}" stroke-width="${.12+cell.cn*.01}" stroke-dasharray="1 11" opacity="${orbOp}"/></svg>
      <svg class="o3" viewBox="0 0 100 100"><circle cx="50" cy="50" r="33" fill="none" stroke="${sc}" stroke-width=".1" stroke-dasharray="3 7" opacity="${orbOp*.5}"/></svg>
    </div>
    <div class="pbr" style="background:${pbr}" id="pbr-${cell.id}"></div>
    <div class="spec"><div class="sb2"></div></div>
    <div style="position:absolute;inset:0px;border-radius:50%;border:1.5px solid rgba(255,255,255,${frOp*.6});pointer-events:none;filter:blur(.4px)"></div>
    <div class="hl" id="hl-${cell.id}"></div>
    <div class="gc" style="background:radial-gradient(circle at 40% 35%,rgba(255,255,255,${.06+cell.tc*.09}) 0%,rgba(255,255,255,.01) 60%,transparent 100%)" id="gc-${cell.id}"></div>
    <div class="ca"><svg viewBox="0 0 40 40"><circle cx="20" cy="20" r="17" fill="${sc}" filter="${caFilt}" opacity="${.04+cell.ac*.09}"/></svg></div>
    <div class="ir" style="background:${irdCol}"></div>
    <div class="ibl" style="background:radial-gradient(circle,${glow} 0%,transparent 70%)"></div>
    <div class="iw" style="color:${sc}">${ICONS[cell.cat]||ICONS.Business}</div>
    <div class="qr"><svg viewBox="0 0 80 80">
      <circle cx="40" cy="40" r="${R}" fill="none" stroke="rgba(255,255,255,.04)" stroke-width="1.5"/>
      <circle cx="40" cy="40" r="${R}" fill="none" stroke="${sc}" stroke-width="1.5" stroke-dasharray="${dash} ${gap}" stroke-linecap="round" opacity=".5" transform="rotate(-90 40 40)"/>
    </svg></div>
    ${cell.sc>0?`<div class="scr"><svg viewBox="0 0 80 80"><circle cx="40" cy="40" r="37" fill="none" stroke="rgba(107,0,24,${.45+cell.sc*.15})" stroke-width="${.7+cell.sc*.2}" stroke-dasharray="3 ${8-cell.sc}" stroke-linecap="round"/></svg></div>`:''}
  </div>
  <div class="ml2">${cell.t}</div>
  <div class="ms2" style="color:${cell.sc>0?'#C06070':cell.st==='UNBOOKED'?'var(--red)':'var(--t3)'}">${cell.st}</div>
  <div class="mtip">
    <div class="mti-cell">${cell.id} · ${cell.cat}</div>
    <div class="mti-row"><span class="mti-k">L1 Status</span><span style="color:${sc}">${cell.st}</span></div>
    <div class="mti-row"><span class="mti-k">L4 QNEU</span><span>${(cell.q*100).toFixed(0)}/100</span></div>
    <div class="mti-row"><span class="mti-k">L0 Conn</span><span>${cell.cn}</span></div>
    <div class="mti-row"><span class="mti-k">L5 Truth</span><span style="color:${cell.tc>.8?'var(--mint)':cell.tc>.5?'var(--amber)':'var(--red)'}">${(cell.tc*100).toFixed(0)}%</span></div>
    ${cell.sc>0?`<div class="mti-row"><span class="mti-k">L7 SCARs</span><span style="color:#C06070">${cell.sc}</span></div>`:''}
  </div>`;
  w.addEventListener('mousemove',e=>{
    const b=w.getBoundingClientRect(),cx=b.left+b.width/2,cy=b.top+b.height/2;
    const ang=Math.atan2(e.clientY-cy,e.clientX-cx)*180/Math.PI;
    const gx=((e.clientX-b.left)/b.width*100).toFixed(1),gy=((e.clientY-b.top)/b.height*100).toFixed(1);
    const p=document.getElementById('pbr-'+cell.id);
    if(p){p.style.background=`conic-gradient(from ${ang}deg,#01010A,${sc}72,#02020C,rgba(255,255,255,.08),${sc}36,#01010A)`;p.style.boxShadow=`0 0 22px ${glow},0 0 48px ${glow.replace('.4','.1')},inset 0 0 16px rgba(0,0,0,.6)`;}
    const gc=document.getElementById('gc-'+cell.id);
    if(gc)gc.style.background=`radial-gradient(circle at ${gx}% ${gy}%,rgba(255,255,255,${.08+cell.tc*.12}) 0%,rgba(255,255,255,.015) 55%,transparent 100%)`;
    const hl=document.getElementById('hl-'+cell.id);if(hl)hl.style.opacity=cell.q*.7;
  });
  w.addEventListener('mouseleave',()=>{
    const p=document.getElementById('pbr-'+cell.id);if(p){p.style.background=pbr;p.style.boxShadow='';}
    const hl=document.getElementById('hl-'+cell.id);if(hl)hl.style.opacity=0;
  });
  return w;
}

function buildCells(){
  const area=document.getElementById('cells-area');area.innerHTML='';
  CATS.forEach(cat=>{
    const cells=CELLS.filter(c=>c.cat===cat.id);if(!cells.length)return;
    const sec=document.createElement('div');sec.className='cat-sec';
    sec.innerHTML=`<div class="cat-hdr" style="border-color:${cat.col}"><span class="cat-hdr-t" style="color:${cat.col}">${cat.id}</span><span class="cat-sub">L0=conn · L1=status · L4=QNEU · L7=SCAR</span></div><div class="mgroup" id="mg-${cat.id}"></div>`;
    area.appendChild(sec);
    setTimeout(()=>{const g=document.getElementById('mg-'+cat.id);cells.forEach(c=>g&&g.appendChild(makeMedal(c)));},0);
  });
}

