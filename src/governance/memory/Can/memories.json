// MODAL
// ──────────────────────────────────────
function openModal(cell){
  const sc=cell.col,rgb=h2r(sc);
  document.getElementById('mod-title').textContent=cell.id+' · '+cell.t;
  document.getElementById('mod-title').style.cssText=`font-family:var(--serif);font-size:18px;font-weight:300;letter-spacing:.18em;background:linear-gradient(135deg,${sc},rgba(238,225,200,.3));-webkit-background-clip:text;-webkit-text-fill-color:transparent`;
  document.getElementById('mod-body').innerHTML=`
    <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(${rgb||'100,100,100'},.04);border:1px solid rgba(${rgb||'100,100,100'},.14);margin-bottom:10px">
      <div style="width:36px;height:36px;border-radius:50%;background:conic-gradient(from 45deg,#01010A,${sc}65,#02020C);border:1px solid rgba(${rgb||'100,100,100'},.35);display:flex;align-items:center;justify-content:center;color:${sc}">${ICONS[cell.cat]||ICONS.Business}</div>
      <div style="flex:1"><div style="font-family:var(--mono);font-size:8.5px;color:${sc};letter-spacing:.15em;text-transform:uppercase">${cell.cat} · ${cell.st}</div><div style="font-family:var(--mono);font-size:7px;color:var(--t3);margin-top:2px">QNEU ${(cell.q*100).toFixed(0)} · ${cell.cn} connections · ${cell.sc} SCARs · Truth ${(cell.tc*100).toFixed(0)}%</div></div>
    </div>
    <div style="font-family:var(--mono);font-size:7px;color:var(--t3);letter-spacing:.2em;text-transform:uppercase;margin-bottom:6px">8-Layer Semantic Map</div>
    <div class="lg">${Object.entries(cell.layers).map(([k,v])=>`<div class="li"><div class="li-k">${k}</div><div class="li-v" style="color:${sc}">${v}</div></div>`).join('')}</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px">
      ${Object.entries(cell.f).map(([k,v])=>`<div class="li"><div class="li-k">${k}</div><div class="li-v" style="color:${sc}">${v}</div></div>`).join('')}
    </div>
    ${cell.sc>0?`<div style="margin-top:8px;padding:7px 9px;border-left:2px solid rgba(107,0,24,.6);background:rgba(107,0,24,.04);font-size:8.5px;color:#C06070;font-family:var(--mono)">⚠ SCAR RING: ${cell.sc} vết đang audit-cell theo dõi</div>`:''}`;
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}

