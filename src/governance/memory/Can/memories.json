const hr2=new Date().getHours();
const mc={night:{m:'NIGHT',c:'var(--lav)'},morning:{m:'MORNING',c:'var(--peach)'},work:{m:'WORK',c:'var(--mint)'},evening:{m:'EVENING',c:'var(--rose)'}};
