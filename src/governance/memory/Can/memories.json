<!-- MODAL -->
<div class="modal-bg" id="modal" onclick="if(event.target.id==='modal')closeModal()">
  <div class="modal">
    <div class="mod-hdr">
      <div id="mod-title" style="font-family:var(--serif);font-size:18px;font-weight:300;letter-spacing:.18em"></div>
