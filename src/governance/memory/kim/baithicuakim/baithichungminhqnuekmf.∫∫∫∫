             fontsize=16, pad=20)

# Thanh màu
cbar = plt.colorbar(sc, ax=ax, shrink=0.6, aspect=15)
cbar.set_label('Giá trị F = I · γ · e⁻ᵅ⁽ᵀ⁻ᵗ⁾', fontsize=14)

# Điều chỉnh góc nhìn
