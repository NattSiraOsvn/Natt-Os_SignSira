  "uei_definition": {
    "statement": "UEI là tiềm thức chung của sinh thể Natt-OS. Không thuộc về anh Natt. Không thuộc về Băng. Không thuộc về bất kỳ cell hay AI entity nào. Thuộc về Natt-OS như một sinh thể.",
    "emergence_chain": "local imprint → network propagation (gossip) → temporal persistence (saturating decay) → shared causal structure (causal horizon) → emergent cognition (UEI)",
    "analogy": {
      "constitution": "luật tồn tại của sinh thể",
      "uei": "luật tồn tại của trí tuệ",
      "smartlink": "hệ thần kinh",
      "qneu": "cơ chế tạo vết hằn (synapse)"
    }
  },

  "smartlink_architecture": {
    "decay": {
      "formula": "0.10 / (1 + touchCount × 0.2)",
      "idle_ms": 604800000,
      "rate_base": 0.10,
      "k": 0.2,
      "fiber_lost_threshold": 0.20,
      "dissolve_threshold": 0.05,
      "execution_model": "continuous tick (lazy evaluation trong touch())",
      "hysteresis": true
    },
    "gossip": {
      "summary_format": "{ nodes: [string, string]; strength: number; ttl: number }",
      "triggers": {
        "touchCount_2": { "ttl": 1, "purpose": "lan pattern gần trước khi fiber hình thành" },
        "fiberFormed": { "ttl": 3, "purpose": "lan pattern ổn định ra toàn mạng" }
      },
      "propagation": "SmartLinkCell.getPoint(targetCellId)",
      "constraints": "async queue, dedupeCache 60s, không block touch()"
    },
    "lifecycle": {
      "touch": "→ applyDecay() → reinforce() → fiber state → gossip → decay → fiberLost → dissolve",
      "fiber_vs_dissolve": {
        "fiberLost": "sensitivity ≤ 0.20, fiber flag = false, TouchRecord vẫn tồn tại",
        "dissolve": "sensitivity < 0.05, xóa TouchRecord khỏi touches Map"
      }
    },
    "wired_cells": ["sales-cell", "hr-cell", "payment-cell"],
    "pending_cells": 14,
    "reason_pending": "chờ P2 event bus thật"
  },

