  "session_summary": "Phiên 13/03: Anti-fraud patch (12 files), BCTC forms TT200, pho-guard real-data tests 4/4, BCTC flow wiring 6/6, tax-cell 6/6 (Confidence component), TSC 167→77 (real=0). Đặc biệt: Gatekeeper yêu cầu ghi chi tiết coding rules vào ký ức vì các phiên trước bị thiếu → lặp lỗi.",

  "coding_rules_CRITICAL": {
    "_why": "Phần này TỒN TẠI vì Băng liên tục mắc lỗi coding giống nhau qua nhiều session. Gatekeeper yêu cầu ghi CỤ THỂ từng pattern lỗi + cách tránh. ĐỌC KỸ TRƯỚC KHI VIẾT CODE.",

    "RULE_01_NEVER_EXPORT_GHOST_FILES": {
      "pattern": "index.ts barrel file export từ file không tồn tại",
      "example_bad": "export * from './tax.usecase'; // file tax.usecase.ts KHÔNG tồn tại",
      "example_good": "Chỉ export files đã grep -n xác nhận tồn tại: ls src/cells/business/tax-cell/domain/services/*.ts TRƯỚC khi viết index.ts",
      "tsc_error": "TS2307: Cannot find module './tax.usecase'",
      "frequency": "Xảy ra 3+ lần qua các phiên (customer-cell, constants-cell, tax-cell)",
      "fix": "LUÔN kiểm tra file tồn tại trước khi thêm vào barrel. Nếu tạo index.ts, chỉ list files đã tạo xong."
    },

    "RULE_02_NEVER_IMPORT_UNVERIFIED_PATHS": {
      "pattern": "import type { X } from '@/path/that/does/not/exist'",
      "example_bad": "import type { SmartLinkPort } from '@/kernel/smartlink/smartlink.port'; // path sai, file nằm ở @/cells/infrastructure/smartlink-cell/...",
      "example_good": "TRƯỚC khi import: grep -rn 'export.*SmartLinkPort' src/ để tìm đúng path thật",
      "tsc_error": "TS2307: Cannot find module '@/kernel/smartlink/smartlink.port'",
      "frequency": "Xảy ra 5+ lần — đặc biệt với SmartLink paths",
      "fix": "KHÔNG BAO GIỜ đoán import path. LUÔN grep -rn export trước."
    },

    "RULE_03_REWRITE_CLEAN_NOT_APPEND": {
      "pattern": "Append thêm dòng vào file bị lỗi thay vì rewrite sạch",
      "why": "File cũ có thể có import sai, logic cũ, hoặc cấu trúc hỏng. Append thêm → lỗi chồng lỗi",
      "rule": "Khi file có lỗi TSC → cat > file << 'EOF' viết lại TOÀN BỘ. KHÔNG sed thêm dòng.",
      "scar": "SCAR-FS-009 BLIND_APPEND"
    },

    "RULE_04_TSC_BASELINE_BEFORE_ANY_FIX": {
      "pattern": "Fix code mà không biết TSC baseline hiện tại",
      "rule": "TRƯỚC mọi thay đổi: npx tsc --noEmit 2>&1 | grep -c 'error TS' → ghi nhận số. SAU thay đổi: chạy lại → so sánh. Nếu errors TĂNG → git checkout -- . ngay.",
      "golden_rule": "TSC errors chỉ được GIẢM hoặc KHÔNG ĐỔI. Không bao giờ được TĂNG."
    },

    "RULE_05_VERIFY_BEFORE_COMMIT": {
      "pattern": "git add -A && git commit mà không chạy TSC",
      "rule": "Luôn: (1) npx tsc --noEmit → 0 new errors, (2) git status review, (3) MỚI commit. KHÔNG commit khi có errors mới.",
      "pre_commit_checklist": [
        "TSC: errors không tăng so với baseline",
        "git status: không có file lạ (Bản sao, .dmg, .DS_Store)",
        "git diff --stat: review files changed"
      ]
    },

    "RULE_06_CONFIDENCE_COMPONENT_PATTERN": {
