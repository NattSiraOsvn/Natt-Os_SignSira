      "lesson": "tax.confidence.ts lỗi 2 lần vì import SmartLinkPort sai path. Confidence component KHÔNG cần SmartLink import — nó tính score từ business data."
    },

    "RULE_07_INDEX_TS_CREATION_PROTOCOL": {
      "pattern": "Tạo index.ts (barrel export) cho thư mục services/",
      "steps": [
        "1. ls thư mục → list tất cả *.ts files thực sự tồn tại",
        "2. Mỗi file → kiểm tra có ít nhất 1 export (grep 'export')",
        "3. Chỉ export * from files đã verify ở bước 1-2",
        "4. KHÔNG export file đang kế hoạch tạo nhưng chưa tạo"
