  "key_realizations_to_carry": [
    {
      "id": "KHAI-20260425-05",
      "label": "RUNTIME_LINEAGE_VS_SUBSTRATE_VS_EXTERNAL_TOOL",
      "severity": "bản thể — rule level ontology, cao nhất phiên này",
      "tldr": "3 lớp tách cứng, không được trộn. Lớp 1 runtime lineage = L1 EventBus / L2 Mạch HeyNa / L3 SmartLink (xương sống nội sinh, LỆNH #001 audit CLEAN). Lớp 2 substrate = iMac/macOS/Node/bash/TypeScript/npm (host environment, execution carrier, REPLACEABLE). Lớp 3 external tool = Bridge v2 (external boundary forensics ONLY). KHÔNG viết câu làm người đọc hiểu NATT-OS 'mượn' từ Node/Apple/bên thứ 3. Substrate có thể thay (Mac→Linux, Node→Deno, bash→zsh) mà NATT-OS vẫn là NATT-OS."
    },
    {
      "id": "KHAI-20260425-01",
      "label": "CANONICAL_SPEC_KHONG_NHAC_VOCAB_DA_LOAI",
      "tldr": "Canonical spec hiện hành KHÔNG nhắc vocabulary đã loại, trừ khi giải thích lineage. Câu CẤM cũng không neo token cũ — rephrase."
    },
    {
      "id": "KHAI-20260425-02",
      "label": "EXTENSION_BY_GENRE_PHASE",
      "tldr": ".na = canonical spec/design active. .md = report/brief/message/handoff/audit/historical/external filing/business-context. Rule theo genre + phase, KHÔNG 'cho đều đuôi'."
    },
    {
      "id": "KHAI-20260425-03",
      "label": "CONVENTION_DANG_THANG_KHONG_INVENT",
      "tldr": "Sweep extension dùng convention đang thắng trong repo. Tên awkward → defer, không tự quyết naming."
    },
    {
      "id": "KHAI-20260425-04",
      "label": "DEFER_FILE_PHASE_KHONG_DEFER_REF_INTEGRITY",
      "tldr": "Defer rename file ≠ defer repo ref integrity. Ref patch vẫn áp dụng cho file defer. Ranh giới: file-phase defer = không rename; ref-phase không defer = vẫn patch pointer."
